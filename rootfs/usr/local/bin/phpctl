#!/bin/sh
set -eu

PROG="${0##*/}"
VERSION="0.2.0-alpha"

OUTPUT_FORMAT="text"

PHP_BIN="${PHP_BIN:-php}"
PHP_FPM_BIN="${PHP_FPM_BIN:-php-fpm}"

PHP_EXT_AVAILABLE_DIR="${PHP_EXT_AVAILABLE_DIR:-/opt/php-ext/conf.d/available}"
PHP_EXT_ACTIVE_DIR="${PHP_EXT_ACTIVE_DIR:-/usr/local/etc/php/conf.d}"

PHP_FPM_POOL_AVAILABLE_DIR="${PHP_FPM_POOL_AVAILABLE_DIR:-/opt/php-fpm/pool.d/available}"
PHP_FPM_POOL_ACTIVE_DIR="${PHP_FPM_POOL_ACTIVE_DIR:-/usr/local/etc/php-fpm.d}"

cmd_exists() {
    command -v "$1" >/dev/null 2>&1
}

mktemp_file() {
    mktemp "${TMPDIR:-/tmp}/phpctl.XXXXXX"
}

json_quote() {
    "${PHP_BIN}" -r 'echo json_encode($argv[1], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);' "$1"
}

json_bool() {
    case "$1" in
        yes|true|1) printf 'true' ;;
        *) printf 'false' ;;
    esac
}

die() {
    msg="$*"
    case "${OUTPUT_FORMAT}" in
        text)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
        json)
            printf '{"ok":false,"error":%s}\n' "$(json_quote "${msg}")" >&2
            ;;
        tsv)
            printf 'ok\terror\nno\t%s\n' "${msg}" >&2
            ;;
        *)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
    esac
    exit 1
}

php_ini_scan_dir() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Scan for additional .ini files in: ||p' | head -n1
}

php_loaded_ini() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Loaded Configuration File: *||p' | head -n1
}

php_extension_dir() {
    "${PHP_BIN}" -r 'echo ini_get("extension_dir"), PHP_EOL;' 2>/dev/null || true
}

php_loaded_extensions_list() {
    "${PHP_BIN}" -r '
        $a = get_loaded_extensions();
        $b = function_exists("get_loaded_extensions") ? get_loaded_extensions(true) : [];
        $exts = array_values(array_unique(array_merge($a, $b)));
        sort($exts, SORT_NATURAL | SORT_FLAG_CASE);
        foreach ($exts as $e) {
            echo $e, PHP_EOL;
        }
    ' 2>/dev/null || true
}

php_ext_version() {
    ext="$1"
    if ext_is_loaded "${ext}"; then
        "${PHP_BIN}" -r '
            $v = phpversion($argv[1]);
            if ($v === false || $v === null || $v === "") {
                $v = "(built-in/unknown)";
            }
            echo $v, PHP_EOL;
        ' "${ext}" 2>/dev/null || printf '%s\n' "-"
    else
        printf '%s\n' "-"
    fi
}

php_parsed_ini_files() {
    "${PHP_BIN}" --ini 2>/dev/null | awk '
        BEGIN { capture=0 }
        /^Additional .ini files parsed:/ { capture=1; next }
        capture == 1 {
            line=$0
            sub(/^[[:space:]]+/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line == "(none)") next
            if (line != "") print line
        }
    ' || true
}

emit_object() {
    tmp="$(mktemp_file)"
    cat > "${tmp}"

    case "${OUTPUT_FORMAT}" in
        text)
            while IFS='=' read -r k v; do
                [ -n "${k}" ] || continue
                printf '%-20s %s\n' "${k}:" "${v}"
            done < "${tmp}"
            ;;
        json)
            TMP_OBJECT_FILE="${tmp}" "${PHP_BIN}" -r '
                $file = getenv("TMP_OBJECT_FILE");
                $out = [];
                foreach (file($file, FILE_IGNORE_NEW_LINES) as $line) {
                    if ($line === "") {
                        continue;
                    }
                    $parts = explode("=", $line, 2);
                    $key = $parts[0];
                    $value = isset($parts[1]) ? $parts[1] : "";
                    if ($value === "yes") {
                        $out[$key] = true;
                    } elseif ($value === "no") {
                        $out[$key] = false;
                    } else {
                        $out[$key] = $value;
                    }
                }
                echo json_encode($out, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
            '
            ;;
        tsv)
            awk -F '=' '
                BEGIN { first=1 }
                {
                    if (!first) printf "\t";
                    printf "%s", $1;
                    first=0;
                    keys[NR]=$1;
                    vals[NR]=substr($0, length($1) + 2);
                    n=NR;
                }
                END {
                    printf "\n";
                    for (i=1; i<=n; i++) {
                        if (i>1) printf "\t";
                        printf "%s", vals[i];
                    }
                    printf "\n";
                }
            ' "${tmp}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${tmp}"
}

pretty_print_tsv() {
    file="$1"
    awk -F '\t' '
        {
            rows[NR]=$0
            for (i=1; i<=NF; i++) {
                if (length($i) > w[i]) {
                    w[i] = length($i)
                }
            }
            if (NF > nf) {
                nf = NF
            }
            nr = NR
        }
        END {
            for (r=1; r<=nr; r++) {
                split(rows[r], f, FS)
                for (i=1; i<=nf; i++) {
                    val = f[i]
                    if (i < nf) {
                        printf "%-*s", w[i] + 2, val
                    } else {
                        printf "%s", val
                    }
                }
                printf "\n"
            }
        }
    ' "${file}"
}

tsv_file_to_json() {
    file="$1"
    TSV_JSON_FILE="${file}" "${PHP_BIN}" -r '
        $file = getenv("TSV_JSON_FILE");
        $lines = file($file, FILE_IGNORE_NEW_LINES);
        if (!$lines || count($lines) === 0) {
            echo "[]\n";
            exit(0);
        }
        $header = explode("\t", array_shift($lines));
        $rows = [];
        foreach ($lines as $line) {
            if ($line === "") {
                continue;
            }
            $cols = explode("\t", $line);
            $row = [];
            foreach ($header as $i => $key) {
                $value = array_key_exists($i, $cols) ? $cols[$i] : "";
                if ($value === "yes") {
                    $row[$key] = true;
                } elseif ($value === "no") {
                    $row[$key] = false;
                } else {
                    $row[$key] = $value;
                }
            }
            $rows[] = $row;
        }
        echo json_encode($rows, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
    '
}

render_table_file() {
    file="$1"
    case "${OUTPUT_FORMAT}" in
        text)
            pretty_print_tsv "${file}"
            ;;
        json)
            tsv_file_to_json "${file}"
            ;;
        tsv)
            cat "${file}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

resolve_ext_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_AVAILABLE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/zz-${ext}.ini"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

resolve_ext_active_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_ACTIVE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/zz-${ext}.ini"
    do
        [ -e "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

ext_name_from_ini() {
    base="$(basename "$1")"
    name="${base#docker-php-ext-}"
    name="${name#zz-}"
    name="${name%.ini}"
    printf '%s\n' "${name}"
}

ext_is_loaded() {
    ext="$1"
    php_loaded_extensions_list | grep -Fxi "${ext}" >/dev/null 2>&1
}

ext_module_file_exists() {
    ext="$1"
    extdir="$(php_extension_dir)"
    [ -n "${extdir}" ] && [ -f "${extdir}/${ext}.so" ]
}

ext_is_available() {
    ext="$1"
    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        return 0
    fi
    if ext_module_file_exists "${ext}"; then
        return 0
    fi
    return 1
}

collect_ext_row() {
    ext="$1"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${ext}" "${avail}" "${active}" "${loaded}" "${version}" "${available_ini}" "${active_ini}"
}

usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
${PROG} - PHP image control utility

Usage:
  ${PROG} [--output text|json|tsv] <command> [subcommand] [options]

Commands:
  help                 Show this help
  version              Show ${PROG} version
  info                 Show PHP runtime information
  paths                Show important filesystem paths
  doctor               Run diagnostics
  self-test            Run quick runtime checks
  ext                  Manage PHP extensions
  fpm                  Manage PHP-FPM pools and config
  ini                  Inspect PHP ini/config values

Examples:
  ${PROG} version
  ${PROG} info
  ${PROG} paths
  ${PROG} doctor
  ${PROG} self-test
  ${PROG} ext list
  ${PROG} ext enable redis
  ${PROG} ext install redis --enable
  ${PROG} fpm pool list
  ${PROG} ini get memory_limit

Run:
  ${PROG} <command> --help
EOF
            ;;
        json|tsv)
            emit_object <<EOF
name=${PROG}
version=${VERSION}
usage=${PROG} [--output text|json|tsv] <command> [subcommand] [options]
commands=help,version,info,paths,doctor,self-test,ext,fpm,ini
default_output=text
output_formats=text,json,tsv
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

show_version() {
    case "${OUTPUT_FORMAT}" in
        text)
            printf '%s v%s\n' "${PROG}" "${VERSION}"
            ;;
        json|tsv)
            emit_object <<EOF
name=${PROG}
version=${VERSION}
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

show_info() {
    php_bin_path="$(command -v "${PHP_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    php_version="$("${PHP_BIN}" -r 'echo PHP_VERSION;' 2>/dev/null || printf '%s\n' "unknown")"
    php_sapi="$("${PHP_BIN}" -r 'echo PHP_SAPI;' 2>/dev/null || printf '%s\n' "unknown")"
    loaded_ini="$(php_loaded_ini)"
    ini_scan_dir="$(php_ini_scan_dir)"
    extension_dir="$(php_extension_dir)"
    php_fpm_bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"

    emit_object <<EOF
php_bin=${php_bin_path}
php_version=${php_version}
php_sapi=${php_sapi}
loaded_ini=${loaded_ini}
ini_scan_dir=${ini_scan_dir}
extension_dir=${extension_dir}
php_fpm_bin=${php_fpm_bin_path}
EOF
}

show_paths() {
    php_bin_path="$(command -v "${PHP_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    php_fpm_bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    loaded_ini="$(php_loaded_ini)"
    ini_scan_dir="$(php_ini_scan_dir)"
    extension_dir="$(php_extension_dir)"

    emit_object <<EOF
php_bin=${php_bin_path}
php_fpm_bin=${php_fpm_bin_path}
loaded_ini=${loaded_ini}
ini_scan_dir=${ini_scan_dir}
extension_dir=${extension_dir}
ext_available_dir=${PHP_EXT_AVAILABLE_DIR}
ext_active_dir=${PHP_EXT_ACTIVE_DIR}
fpm_pool_available_dir=${PHP_FPM_POOL_AVAILABLE_DIR}
fpm_pool_active_dir=${PHP_FPM_POOL_ACTIVE_DIR}
EOF
}

show_doctor() {
    tmp="$(mktemp_file)"
    printf 'check\tstatus\tdetails\n' > "${tmp}"

    if cmd_exists "${PHP_BIN}"; then
        php_bin_status="ok"
        php_bin_details="$(command -v "${PHP_BIN}" 2>/dev/null || true)"
    else
        php_bin_status="fail"
        php_bin_details="php binary not found"
    fi
    printf 'php_bin\t%s\t%s\n' "${php_bin_status}" "${php_bin_details}" >> "${tmp}"

    loaded_ini="$(php_loaded_ini)"
    if [ -n "${loaded_ini}" ] && [ "${loaded_ini}" != "(none)" ]; then
        ini_status="ok"
        ini_details="${loaded_ini}"
    else
        ini_status="warn"
        ini_details="no loaded php.ini"
    fi
    printf 'loaded_ini\t%s\t%s\n' "${ini_status}" "${ini_details}" >> "${tmp}"

    extdir="$(php_extension_dir)"
    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        extdir_status="ok"
        extdir_details="${extdir}"
    else
        extdir_status="warn"
        extdir_details="${extdir:-extension_dir missing}"
    fi
    printf 'extension_dir\t%s\t%s\n' "${extdir_status}" "${extdir_details}" >> "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        active_dir_status="ok"
        active_dir_details="${PHP_EXT_ACTIVE_DIR}"
    else
        active_dir_status="warn"
        active_dir_details="missing: ${PHP_EXT_ACTIVE_DIR}"
    fi
    printf 'ext_active_dir\t%s\t%s\n' "${active_dir_status}" "${active_dir_details}" >> "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        avail_dir_status="ok"
        avail_dir_details="${PHP_EXT_AVAILABLE_DIR}"
    else
        avail_dir_status="warn"
        avail_dir_details="missing: ${PHP_EXT_AVAILABLE_DIR}"
    fi
    printf 'ext_available_dir\t%s\t%s\n' "${avail_dir_status}" "${avail_dir_details}" >> "${tmp}"

    if cmd_exists "${PHP_FPM_BIN}"; then
        fpm_bin_status="ok"
        fpm_bin_details="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || true)"
    else
        fpm_bin_status="info"
        fpm_bin_details="php-fpm binary not available"
    fi
    printf 'php_fpm_bin\t%s\t%s\n' "${fpm_bin_status}" "${fpm_bin_details}" >> "${tmp}"

    if cmd_exists "${PHP_FPM_BIN}"; then
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            fpm_test_status="ok"
            fpm_test_details="configuration valid"
        else
            fpm_test_status="warn"
            fpm_test_details="configuration test failed"
        fi
    else
        fpm_test_status="info"
        fpm_test_details="skipped"
    fi
    printf 'php_fpm_test\t%s\t%s\n' "${fpm_test_status}" "${fpm_test_details}" >> "${tmp}"

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

show_self_test() {
    tmp="$(mktemp_file)"
    printf 'test\tstatus\tdetails\n' > "${tmp}"

    if "${PHP_BIN}" -v >/dev/null 2>&1; then
        s1="ok"
        d1="$("${PHP_BIN}" -v 2>/dev/null | head -n1 || true)"
    else
        s1="fail"
        d1="php -v failed"
    fi
    printf 'php_version\t%s\t%s\n' "${s1}" "${d1}" >> "${tmp}"

    if "${PHP_BIN}" -m >/dev/null 2>&1; then
        s2="ok"
        d2="php -m succeeded"
    else
        s2="fail"
        d2="php -m failed"
    fi
    printf 'php_modules\t%s\t%s\n' "${s2}" "${d2}" >> "${tmp}"

    if "${PHP_BIN}" --ini >/dev/null 2>&1; then
        s3="ok"
        d3="php --ini succeeded"
    else
        s3="fail"
        d3="php --ini failed"
    fi
    printf 'php_ini\t%s\t%s\n' "${s3}" "${d3}" >> "${tmp}"

    if cmd_exists "${PHP_FPM_BIN}"; then
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            s4="ok"
            d4="php-fpm configuration valid"
        else
            s4="fail"
            d4="php-fpm configuration invalid"
        fi
    else
        s4="info"
        d4="php-fpm not available"
    fi
    printf 'php_fpm_test\t%s\t%s\n' "${s4}" "${d4}" >> "${tmp}"

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ext <subcommand> [args]

Subcommands:
  list                 List discovered extensions
  list-loaded          List loaded extensions
  versions             Show loaded extensions with versions
  pecl-list            Show PECL registry packages
  so-list              Show extension directory shared objects
  status <ext>         Show status of one extension
  install <ext>        Install one extension via PECL
  enable <ext>         Enable extension by linking ini into active dir
  disable <ext>        Disable extension by removing active ini
  enable-all           Enable all available extensions
  disable-all          Disable all active extension ini files
  doctor               Run extension-specific diagnostics
  help                 Show this help

Examples:
  ${PROG} ext list
  ${PROG} ext status redis
  ${PROG} ext install redis --enable
  ${PROG} ext enable redis
  ${PROG} ext disable redis
  ${PROG} ext enable-all
  ${PROG} ext doctor
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ext
usage=${PROG} ext <subcommand> [args]
subcommands=list,list-loaded,versions,pecl-list,so-list,status,install,enable,disable,enable-all,disable-all,doctor,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ext_list() {
    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        for f in "${PHP_EXT_AVAILABLE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ext_name_from_ini "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        for f in "${PHP_EXT_ACTIVE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ext_name_from_ini "${f}" >> "${tmp_names}"
        done
    fi

    php_loaded_extensions_list >> "${tmp_names}"

    printf 'name\tavailable\tactive\tloaded\tversion\tavailable_ini\tactive_ini\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r ext; do
            [ -n "${ext}" ] || continue
            collect_ext_row "${ext}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"

    rm -f "${tmp_names}" "${tmp_rows}"
}

ext_list_loaded() {
    tmp="$(mktemp_file)"
    printf 'name\n' > "${tmp}"
    php_loaded_extensions_list | while IFS= read -r ext; do
        [ -n "${ext}" ] || continue
        printf '%s\n' "${ext}"
    done >> "${tmp}"
    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_versions() {
    tmp="$(mktemp_file)"
    printf 'name\tversion\n' > "${tmp}"
    php_loaded_extensions_list | while IFS= read -r ext; do
        [ -n "${ext}" ] || continue
        printf '%s\t%s\n' "${ext}" "$(php_ext_version "${ext}")"
    done >> "${tmp}"
    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_pecl_list() {
    tmp="$(mktemp_file)"
    printf 'name\tversion\tstate\n' > "${tmp}"

    if cmd_exists pecl; then
        pecl list 2>/dev/null | awk '
            BEGIN { capture=0 }
            /^Package[[:space:]]+Version[[:space:]]+State/ { capture=1; next }
            /^=+/ { next }
            capture == 1 && NF >= 3 { print $1 "\t" $2 "\t" $3 }
        ' >> "${tmp}" || true
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_so_list() {
    tmp="$(mktemp_file)"
    extdir="$(php_extension_dir)"
    printf 'name\tpath\tsize\n' > "${tmp}"

    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        find "${extdir}" -maxdepth 1 -type f -name '*.so' | sort | while IFS= read -r sofile; do
            [ -n "${sofile}" ] || continue
            name="$(basename "${sofile}" .so)"
            size="$(wc -c < "${sofile}" | tr -d '[:space:]')"
            printf '%s\t%s\t%s\n' "${name}" "${sofile}" "${size}"
        done >> "${tmp}"
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_status() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext status <ext>"
    ext="$1"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    emit_object <<EOF
name=${ext}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
available_ini=${available_ini}
active_ini=${active_ini}
extension_dir=$(php_extension_dir)
EOF
}

ext_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext enable <ext>"
    ext="$1"
    ini="$(resolve_ext_ini "${ext}" 2>/dev/null || true)"

    [ -n "${ini}" ] || die "No available ini found for extension: ${ext}"

    mkdir -p "${PHP_EXT_ACTIVE_DIR}"
    ln -sf "${ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${ini}")"

    emit_object <<EOF
ok=yes
action=enable
extension=${ext}
active=yes
active_ini=${PHP_EXT_ACTIVE_DIR}/$(basename "${ini}")
EOF
}

ext_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext disable <ext>"
    ext="$1"

    removed="no"
    removed_ini="-"

    for candidate in \
        "${PHP_EXT_ACTIVE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/zz-${ext}.ini"
    do
        if [ -e "${candidate}" ]; then
            rm -f "${candidate}"
            removed="yes"
            removed_ini="${candidate}"
        fi
    done

    emit_object <<EOF
ok=yes
action=disable
extension=${ext}
removed=${removed}
removed_ini=${removed_ini}
EOF
}

ext_enable_all() {
    mkdir -p "${PHP_EXT_ACTIVE_DIR}"
    tmp="$(mktemp_file)"
    printf 'name\tresult\tactive_ini\n' > "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        for f in "${PHP_EXT_AVAILABLE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ln -sf "${f}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${f}")"
            printf '%s\tenabled\t%s\n' "$(ext_name_from_ini "${f}")" "${PHP_EXT_ACTIVE_DIR}/$(basename "${f}")" >> "${tmp}"
        done
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_disable_all() {
    tmp="$(mktemp_file)"
    printf 'name\tresult\tactive_ini\n' > "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        for f in "${PHP_EXT_ACTIVE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            printf '%s\tdisabled\t%s\n' "$(ext_name_from_ini "${f}")" "${f}" >> "${tmp}"
            rm -f "${f}"
        done
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_doctor() {
    tmp="$(mktemp_file)"
    printf 'check\tstatus\tdetails\n' > "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        s1="ok"
        d1="${PHP_EXT_AVAILABLE_DIR}"
    else
        s1="warn"
        d1="missing: ${PHP_EXT_AVAILABLE_DIR}"
    fi
    printf 'available_dir\t%s\t%s\n' "${s1}" "${d1}" >> "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        s2="ok"
        d2="${PHP_EXT_ACTIVE_DIR}"
    else
        s2="warn"
        d2="missing: ${PHP_EXT_ACTIVE_DIR}"
    fi
    printf 'active_dir\t%s\t%s\n' "${s2}" "${d2}" >> "${tmp}"

    extdir="$(php_extension_dir)"
    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        s3="ok"
        d3="${extdir}"
    else
        s3="warn"
        d3="${extdir:-extension_dir missing}"
    fi
    printf 'extension_dir\t%s\t%s\n' "${s3}" "${d3}" >> "${tmp}"

    loaded_count="$(php_loaded_extensions_list | awk 'NF { c++ } END { print c+0 }')"
    printf 'loaded_extensions\tok\t%s\n' "${loaded_count}" >> "${tmp}"

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_install_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ext install <ext> [options]

Options:
  --enable                 Enable extension after successful install
  --version <ver>          Install a specific PECL version
  --apk <pkgs...>          Additional build dependencies installed via apk
  --runtime <pkgs...>      Additional runtime packages installed via apk
  --force                  Reinstall even if extension appears installed
  --no-cleanup             Do not remove temporary build dependencies
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ext_install
usage=${PROG} ext install <ext> [options]
options=--enable,--version,--apk,--runtime,--force,--no-cleanup
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ext_install() {
    [ $# -gt 0 ] || die "Usage: ${PROG} ext install <ext> [options]"

    ext="$1"
    shift

    enable_after="no"
    pecl_version=""
    apk_deps=""
    runtime_pkgs=""
    force="no"
    no_cleanup="no"

    while [ $# -gt 0 ]; do
        case "$1" in
            --enable)
                enable_after="yes"
                shift
                ;;
            --version)
                shift
                [ $# -gt 0 ] || die "Missing value for --version"
                pecl_version="$1"
                shift
                ;;
            --apk)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    apk_deps="${apk_deps} $1"
                    shift
                done
                ;;
            --runtime)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    runtime_pkgs="${runtime_pkgs} $1"
                    shift
                done
                ;;
            --force)
                force="yes"
                shift
                ;;
            --no-cleanup)
                no_cleanup="yes"
                shift
                ;;
            -h|--help)
                ext_install_usage
                return 0
                ;;
            *)
                die "Unknown install option: $1"
                ;;
        esac
    done

    if [ "${force}" != "yes" ]; then
        if ext_is_available "${ext}" || resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
            die "Extension already appears installed: ${ext}. Use --force to reinstall."
        fi
    fi

    if [ -n "${runtime_pkgs# }" ]; then
        apk add --no-cache ${runtime_pkgs}
    fi

    apk add --no-cache --virtual .php-ext-build ${PHPIZE_DEPS:-} linux-headers pkgconfig re2c git ${apk_deps} >/dev/null 2>&1 || true

    pecl channel-update pecl.php.net >/dev/null 2>&1 || true

    package="${ext}"
    if [ -n "${pecl_version}" ]; then
        package="${ext}-${pecl_version}"
    fi

    yes '' | pecl install "${package}" >/dev/null
    docker-php-ext-enable "${ext}" >/dev/null 2>&1 || true

    mkdir -p "${PHP_EXT_AVAILABLE_DIR}"
    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        moved_any="no"
        for f in "${PHP_EXT_ACTIVE_DIR}"/*"${ext}"*.ini; do
            [ -e "${f}" ] || continue
            mv "${f}" "${PHP_EXT_AVAILABLE_DIR}/$(basename "${f}")"
            moved_any="yes"
        done
        if [ "${moved_any}" = "no" ]; then
            if [ ! -f "${PHP_EXT_AVAILABLE_DIR}/docker-php-ext-${ext}.ini" ]; then
                printf 'extension=%s\n' "${ext}" > "${PHP_EXT_AVAILABLE_DIR}/docker-php-ext-${ext}.ini"
            fi
        fi
    fi

    if [ "${enable_after}" = "yes" ]; then
        ini="$(resolve_ext_ini "${ext}" 2>/dev/null || true)"
        [ -n "${ini}" ] || die "Installed extension but no available ini found for: ${ext}"
        mkdir -p "${PHP_EXT_ACTIVE_DIR}"
        ln -sf "${ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${ini}")"
    fi

    if [ "${no_cleanup}" != "yes" ]; then
        apk del .php-ext-build >/dev/null 2>&1 || true
    fi

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    emit_object <<EOF
ok=yes
action=install
extension=${ext}
requested_package=${package}
enabled=${enable_after}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
available_ini=${available_ini}
active_ini=${active_ini}
cleanup_performed=$( [ "${no_cleanup}" = "yes" ] && printf '%s' "no" || printf '%s' "yes" )
EOF
}

handle_ext() {
    [ $# -gt 0 ] || { ext_usage; return 0; }

    case "$1" in
        help|--help|-h)
            ext_usage
            ;;
        list)
            shift
            ext_list "$@"
            ;;
        list-loaded)
            shift
            ext_list_loaded "$@"
            ;;
        versions)
            shift
            ext_versions "$@"
            ;;
        pecl-list)
            shift
            ext_pecl_list "$@"
            ;;
        so-list)
            shift
            ext_so_list "$@"
            ;;
        status)
            shift
            ext_status "$@"
            ;;
        install)
            shift
            ext_install "$@"
            ;;
        enable)
            shift
            ext_enable "$@"
            ;;
        disable)
            shift
            ext_disable "$@"
            ;;
        enable-all)
            shift
            ext_enable_all "$@"
            ;;
        disable-all)
            shift
            ext_disable_all "$@"
            ;;
        doctor)
            shift
            ext_doctor "$@"
            ;;
        *)
            die "Unknown ext subcommand: $1"
            ;;
    esac
}

fpm_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} fpm <subcommand> [args]

Subcommands:
  status               Show php-fpm binary and config test result
  test                 Run php-fpm -t
  pool list            List available and active pools
  pool enable <name>   Enable pool config by linking it into active dir
  pool disable <name>  Disable pool config by removing it from active dir
  pool show <name>     Show pool file paths
  help                 Show this help

Examples:
  ${PROG} fpm status
  ${PROG} fpm test
  ${PROG} fpm pool list
  ${PROG} fpm pool enable www
  ${PROG} fpm pool disable www
  ${PROG} fpm pool show www
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=fpm
usage=${PROG} fpm <subcommand> [args]
subcommands=status,test,pool list,pool enable,pool disable,pool show,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

resolve_pool_available() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.pool.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done
    return 1
}

resolve_pool_active() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.pool.conf" \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}"
    do
        [ -e "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done
    return 1
}

pool_name_from_path() {
    base="$(basename "$1")"
    base="${base%.pool.conf}"
    base="${base%.conf}"
    printf '%s\n' "${base}"
}

fpm_status() {
    bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    available="no"
    config_ok="no"

    if cmd_exists "${PHP_FPM_BIN}"; then
        available="yes"
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            config_ok="yes"
        fi
    fi

    emit_object <<EOF
php_fpm_bin=${bin_path}
available=${available}
config_ok=${config_ok}
EOF
}

fpm_test() {
    if ! cmd_exists "${PHP_FPM_BIN}"; then
        die "php-fpm binary not found"
    fi

    if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
        status="ok"
        ok="yes"
        details="configuration valid"
    else
        status="fail"
        ok="no"
        details="configuration invalid"
    fi

    emit_object <<EOF
ok=${ok}
status=${status}
details=${details}
EOF
}

fpm_pool_list() {
    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_AVAILABLE_DIR}"/*; do
            [ -e "${f}" ] || continue
            pool_name_from_path "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_ACTIVE_DIR}"/*; do
            [ -e "${f}" ] || continue
            pool_name_from_path "${f}" >> "${tmp_names}"
        done
    fi

    printf 'name\tavailable\tactive\tavailable_path\tactive_path\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r name; do
            [ -n "${name}" ] || continue
            avail="no"
            active="no"
            available_path="-"
            active_path="-"

            if resolve_pool_available "${name}" >/dev/null 2>&1; then
                avail="yes"
                available_path="$(resolve_pool_available "${name}")"
            fi

            if resolve_pool_active "${name}" >/dev/null 2>&1; then
                active="yes"
                active_path="$(resolve_pool_active "${name}")"
            fi

            printf '%s\t%s\t%s\t%s\t%s\n' "${name}" "${avail}" "${active}" "${available_path}" "${active_path}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"

    rm -f "${tmp_names}" "${tmp_rows}"
}

fpm_pool_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool enable <name>"
    name="$1"
    src="$(resolve_pool_available "${name}" 2>/dev/null || true)"
    [ -n "${src}" ] || die "Pool not found in available dir: ${name}"

    mkdir -p "${PHP_FPM_POOL_ACTIVE_DIR}"
    ln -sf "${src}" "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")"

    emit_object <<EOF
ok=yes
action=enable
pool=${name}
active=yes
active_path=${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")
EOF
}

fpm_pool_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool disable <name>"
    name="$1"
    dst="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    [ -n "${dst}" ] || die "Pool not active: ${name}"

    rm -f "${dst}"

    emit_object <<EOF
ok=yes
action=disable
pool=${name}
active=no
removed_path=${dst}
EOF
}

fpm_pool_show() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool show <name>"
    name="$1"

    avail="no"
    active="no"
    available_path="-"
    active_path="-"

    if resolve_pool_available "${name}" >/dev/null 2>&1; then
        avail="yes"
        available_path="$(resolve_pool_available "${name}")"
    fi

    if resolve_pool_active "${name}" >/dev/null 2>&1; then
        active="yes"
        active_path="$(resolve_pool_active "${name}")"
    fi

    emit_object <<EOF
pool=${name}
available=${avail}
active=${active}
available_path=${available_path}
active_path=${active_path}
EOF
}

handle_fpm() {
    [ $# -gt 0 ] || { fpm_usage; return 0; }

    case "$1" in
        help|--help|-h)
            fpm_usage
            ;;
        status)
            shift
            fpm_status "$@"
            ;;
        test)
            shift
            fpm_test "$@"
            ;;
        pool)
            shift
            [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool <list|enable|disable|show> ..."
            case "$1" in
                help|--help|-h)
                    fpm_usage
                    ;;
                list)
                    shift
                    fpm_pool_list "$@"
                    ;;
                enable)
                    shift
                    fpm_pool_enable "$@"
                    ;;
                disable)
                    shift
                    fpm_pool_disable "$@"
                    ;;
                show)
                    shift
                    fpm_pool_show "$@"
                    ;;
                *)
                    die "Unknown fpm pool subcommand: $1"
                    ;;
            esac
            ;;
        *)
            die "Unknown fpm subcommand: $1"
            ;;
    esac
}

ini_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ini <subcommand> [args]

Subcommands:
  show                 Show php ini information
  get <key>            Read a single ini value
  scan                 Show additional ini scan directory
  loaded               Show loaded php.ini path
  help                 Show this help

Examples:
  ${PROG} ini show
  ${PROG} ini get memory_limit
  ${PROG} ini get opcache.enable
  ${PROG} ini scan
  ${PROG} ini loaded
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ini
usage=${PROG} ini <subcommand> [args]
subcommands=show,get,scan,loaded,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ini_show() {
    if [ "${OUTPUT_FORMAT}" = "text" ]; then
        "${PHP_BIN}" --ini
        return 0
    fi

    loaded_ini="$(php_loaded_ini)"
    scan_dir="$(php_ini_scan_dir)"
    parsed_files="$(php_parsed_ini_files | paste -sd ',' -)"
    parsed_count="$(php_parsed_ini_files | awk 'NF { c++ } END { print c+0 }')"

    emit_object <<EOF
loaded_ini=${loaded_ini}
scan_dir=${scan_dir}
parsed_files_count=${parsed_count}
parsed_files=${parsed_files}
EOF
}

ini_get() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ini get <key>"
    key="$1"
    value="$("${PHP_BIN}" -r 'echo ini_get($argv[1]), PHP_EOL;' "${key}" 2>/dev/null || true)"

    emit_object <<EOF
key=${key}
value=${value}
EOF
}

ini_scan() {
    emit_object <<EOF
scan_dir=$(php_ini_scan_dir)
EOF
}

ini_loaded() {
    emit_object <<EOF
loaded_ini=$(php_loaded_ini)
EOF
}

handle_ini() {
    [ $# -gt 0 ] || { ini_usage; return 0; }

    case "$1" in
        help|--help|-h)
            ini_usage
            ;;
        show)
            shift
            ini_show "$@"
            ;;
        get)
            shift
            ini_get "$@"
            ;;
        scan)
            shift
            ini_scan "$@"
            ;;
        loaded)
            shift
            ini_loaded "$@"
            ;;
        *)
            die "Unknown ini subcommand: $1"
            ;;
    esac
}

while [ $# -gt 0 ]; do
    case "$1" in
        --output)
            shift
            [ $# -gt 0 ] || die "Missing value for --output"
            case "$1" in
                text|json|tsv)
                    OUTPUT_FORMAT="$1"
                    ;;
                *)
                    die "Unsupported output format: $1"
                    ;;
            esac
            shift
            ;;
        *)
            break
            ;;
    esac
done

case "${1:-help}" in
    help|--help|-h)
        usage
        ;;
    version)
        shift
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "${OUTPUT_FORMAT}" in
                text)
                    cat <<EOF
Usage:
  ${PROG} version

Show ${PROG} version.
EOF
                    ;;
                json|tsv)
                    emit_object <<EOF
section=version
usage=${PROG} version
EOF
                    ;;
                *)
                    die "Unsupported output format: ${OUTPUT_FORMAT}"
                    ;;
            esac
        else
            show_version
        fi
        ;;
    info)
        shift
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "${OUTPUT_FORMAT}" in
                text)
                    cat <<EOF
Usage:
  ${PROG} info

Show basic PHP runtime information.
EOF
                    ;;
                json|tsv)
                    emit_object <<EOF
section=info
usage=${PROG} info
EOF
                    ;;
                *)
                    die "Unsupported output format: ${OUTPUT_FORMAT}"
                    ;;
            esac
        else
            show_info
        fi
        ;;
    paths)
        shift
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "${OUTPUT_FORMAT}" in
                text)
                    cat <<EOF
Usage:
  ${PROG} paths

Show important filesystem paths used by PHP, extensions and FPM.
EOF
                    ;;
                json|tsv)
                    emit_object <<EOF
section=paths
usage=${PROG} paths
EOF
                    ;;
                *)
                    die "Unsupported output format: ${OUTPUT_FORMAT}"
                    ;;
            esac
        else
            show_paths
        fi
        ;;
    doctor)
        shift
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "${OUTPUT_FORMAT}" in
                text)
                    cat <<EOF
Usage:
  ${PROG} doctor

Run general diagnostics for PHP runtime, ini, extensions and php-fpm.
EOF
                    ;;
                json|tsv)
                    emit_object <<EOF
section=doctor
usage=${PROG} doctor
EOF
                    ;;
                *)
                    die "Unsupported output format: ${OUTPUT_FORMAT}"
                    ;;
            esac
        else
            show_doctor
        fi
        ;;
    self-test)
        shift
        if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
            case "${OUTPUT_FORMAT}" in
                text)
                    cat <<EOF
Usage:
  ${PROG} self-test

Run a quick operational test of PHP CLI, modules and php-fpm config.
EOF
                    ;;
                json|tsv)
                    emit_object <<EOF
section=self-test
usage=${PROG} self-test
EOF
                    ;;
                *)
                    die "Unsupported output format: ${OUTPUT_FORMAT}"
                    ;;
            esac
        else
            show_self_test
        fi
        ;;
    ext)
        shift
        handle_ext "$@"
        ;;
    fpm)
        shift
        handle_fpm "$@"
        ;;
    ini)
        shift
        handle_ini "$@"
        ;;
    *)
        usage
        die "Unknown command: $1"
        ;;
esac