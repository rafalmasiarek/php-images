PHP_FPM_POOL_TEMPLATE="${PHPCTL_PHP_FPM_POOL_TEMPLATE:-${PHP_FPM_POOL_TEMPLATE:-}}"
PHP_FPM_RELOAD_SIGNAL="${PHPCTL_PHP_FPM_RELOAD_SIGNAL:-${PHP_FPM_RELOAD_SIGNAL:-HUP}}"

PHP_SRC_DIR="${PHPCTL_PHP_SRC_DIR:-${PHP_SRC_DIR:-/usr/src/php}}"
PHP_BUILD_DEPS_VIRTUAL="${PHPCTL_PHP_BUILD_DEPS_VIRTUAL:-.phpctl-php-ext-build}"
PHP_BUILD_DEPS="${PHPCTL_PHP_BUILD_DEPS:-${PHP_BUILD_DEPS:-${PHPIZE_DEPS:-autoconf dpkg-dev dpkg file g++ gcc libc-dev make pkgconf re2c} linux-headers pkgconfig re2c git binutils}}"

PHPCTL_SERVE_LISTEN="${PHPCTL_SERVE_LISTEN:-0.0.0.0:8080}"
PHPCTL_SERVER_LISTEN="${PHPCTL_SERVER_LISTEN:-${PHPCTL_SERVE_LISTEN}}"
PHPCTL_CLIENT_CONF="${PHPCTL_CLIENT_CONF:-${HOME:-/root}/.phpctl/client.conf}"

PHPCTL_WORKER_ID="${PHPCTL_WORKER_ID:-}"
PHPCTL_WORKER_GROUP="${PHPCTL_WORKER_GROUP:-}"
PHPCTL_WORKER_LABELS_JSON="${PHPCTL_WORKER_LABELS_JSON:-}"
PHPCTL_WORKER_MAX_POOLS="${PHPCTL_WORKER_MAX_POOLS:-0}"
PHPCTL_WORKER_MAX_CHILDREN_TOTAL="${PHPCTL_WORKER_MAX_CHILDREN_TOTAL:-0}"
PHPCTL_WORKER_MAX_REPLICAS="${PHPCTL_WORKER_MAX_REPLICAS:-0}"
PHPCTL_WORKER_MAX_MEMORY_MB="${PHPCTL_WORKER_MAX_MEMORY_MB:-0}"

PHPCTL_POOL_META_PREFIX="${PHPCTL_POOL_META_PREFIX:-phpctl.meta.}"

PHPCTL_REMOTE_MODE=""
PHPCTL_REMOTE_HOST=""
PHPCTL_REMOTE_CREDENTIALS=""

SELF_PATH="${PHPCTL_SELF_PATH:-$0}"

cmd_exists() {
    command -v "$1" >/dev/null 2>&1
}

mktemp_file() {
    mktemp "${TMPDIR:-/tmp}/phpctl.XXXXXX"
}

json_quote() {
    "${PHP_BIN}" -r 'echo json_encode($argv[1], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);' "$1"
}

die() {
    msg="$*"
    case "${OUTPUT_FORMAT}" in
        text)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
        json)
            printf '{"ok":false,"error":%s}\n' "$(json_quote "${msg}")" >&2
            ;;
        tsv)
            printf 'ok\terror\nno\t%s\n' "${msg}" >&2
            ;;
        *)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
    esac
    exit 1
}

php_ini_scan_dir() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Scan for additional .ini files in: ||p' | head -n1
}

php_loaded_ini() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Loaded Configuration File: *||p' | head -n1
}

php_extension_dir() {
    "${PHP_BIN}" -r 'echo ini_get("extension_dir"), PHP_EOL;' 2>/dev/null || true
}

php_loaded_extensions_list() {
    "${PHP_BIN}" -r '
        $a = get_loaded_extensions();
        $b = function_exists("get_loaded_extensions") ? get_loaded_extensions(true) : [];
        $exts = array_values(array_unique(array_merge($a, $b)));
        sort($exts, SORT_NATURAL | SORT_FLAG_CASE);
        foreach ($exts as $e) {
            echo $e, PHP_EOL;
        }
    ' 2>/dev/null || true
}

php_ext_version() {
    ext="$1"
    if ext_is_loaded "${ext}"; then
        "${PHP_BIN}" -r '
            $v = phpversion($argv[1]);
            if ($v === false || $v === null || $v === "") {
                $v = "(built-in/unknown)";
            }
            echo $v, PHP_EOL;
        ' "${ext}" 2>/dev/null || printf '%s\n' "-"
    else
        printf '%s\n' "-"
    fi
}

php_parsed_ini_files() {
    "${PHP_BIN}" --ini 2>/dev/null | awk '
        BEGIN { capture=0 }
        /^Additional .ini files parsed:/ { capture=1; next }
        capture == 1 {
            line=$0
            sub(/^[[:space:]]+/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line == "(none)") next
            if (line != "") print line
        }
    ' || true
}

emit_object() {
    tmp="$(mktemp_file)"
    cat > "${tmp}"

    case "${OUTPUT_FORMAT}" in
        text)
            while IFS='=' read -r k v; do
                [ -n "${k}" ] || continue
                printf '%-20s %s\n' "${k}:" "${v}"
            done < "${tmp}"
            ;;
        json)
            TMP_OBJECT_FILE="${tmp}" "${PHP_BIN}" -r '
                $file = getenv("TMP_OBJECT_FILE");
                $out = [];
                foreach (file($file, FILE_IGNORE_NEW_LINES) as $line) {
                    if ($line === "") {
                        continue;
                    }
                    $parts = explode("=", $line, 2);
                    $key = $parts[0];
                    $value = isset($parts[1]) ? $parts[1] : "";
                    if ($value === "yes") {
                        $out[$key] = true;
                    } elseif ($value === "no") {
                        $out[$key] = false;
                    } else {
                        $out[$key] = $value;
                    }
                }
                echo json_encode($out, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
            '
            ;;
        tsv)
            awk -F '=' '
                BEGIN { first=1 }
                {
                    if (!first) printf "\t";
                    printf "%s", $1;
                    first=0;
                    vals[NR]=substr($0, length($1) + 2);
                    n=NR;
                }
                END {
                    printf "\n";
                    for (i=1; i<=n; i++) {
                        if (i>1) printf "\t";
                        printf "%s", vals[i];
                    }
                    printf "\n";
                }
            ' "${tmp}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${tmp}"
}

pretty_print_tsv() {
    file="$1"
    awk -F '\t' '
        {
            rows[NR]=$0
            for (i=1; i<=NF; i++) {
                if (length($i) > w[i]) {
                    w[i] = length($i)
                }
            }
            if (NF > nf) {
                nf = NF
            }
            nr = NR
        }
        END {
            for (r=1; r<=nr; r++) {
                split(rows[r], f, FS)
                for (i=1; i<=nf; i++) {
                    val = f[i]
                    if (i < nf) {
                        printf "%-*s", w[i] + 2, val
                    } else {
                        printf "%s", val
                    }
                }
                printf "\n"
            }
        }
    ' "${file}"
}

tsv_file_to_json() {
    file="$1"
    TSV_JSON_FILE="${file}" "${PHP_BIN}" -r '
        $file = getenv("TSV_JSON_FILE");
        $lines = file($file, FILE_IGNORE_NEW_LINES);
        if (!$lines || count($lines) === 0) {
            echo "[]\n";
            exit(0);
        }
        $header = explode("\t", array_shift($lines));
        $rows = [];
        foreach ($lines as $line) {
            if ($line === "") {
                continue;
            }
            $cols = explode("\t", $line);
            $row = [];
            foreach ($header as $i => $key) {
                $value = array_key_exists($i, $cols) ? $cols[$i] : "";
                if ($value === "yes") {
                    $row[$key] = true;
                } elseif ($value === "no") {
                    $row[$key] = false;
                } else {
                    $row[$key] = $value;
                }
            }
            $rows[] = $row;
        }
        echo json_encode($rows, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
    '
}

render_table_file() {
    file="$1"
    case "${OUTPUT_FORMAT}" in
        text)
            pretty_print_tsv "${file}"
            ;;
        json)
            tsv_file_to_json "${file}"
            ;;
        tsv)
            cat "${file}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

apk_add_if_any() {
    if [ $# -gt 0 ] && [ -n "$*" ]; then
        apk add --no-cache "$@"
    fi
}

php_build_deps_install() {
    if apk info --installed "${PHP_BUILD_DEPS_VIRTUAL}" >/dev/null 2>&1; then
        return 0
    fi
    apk add --no-cache --virtual "${PHP_BUILD_DEPS_VIRTUAL}" ${PHP_BUILD_DEPS}
}

php_build_deps_cleanup() {
    apk del "${PHP_BUILD_DEPS_VIRTUAL}" >/dev/null 2>&1 || true
}

php_fpm_master_pid() {
    if cmd_exists pidof; then
        pidof "$(basename "${PHP_FPM_BIN}")" 2>/dev/null | awk '{print $1}' | head -n1
        return 0
    fi
    ps 2>/dev/null | awk '/php-fpm: master process/ { print $1; exit }'
}

resolve_ext_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_AVAILABLE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/zz-${ext}.ini"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

resolve_ext_active_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_ACTIVE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/zz-${ext}.ini"
    do
        [ -e "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

ext_name_from_ini() {
    base="$(basename "$1")"
    name="${base#docker-php-ext-}"
    name="${name#zz-}"
    name="${name%.ini}"
    printf '%s\n' "${name}"
}

ext_is_loaded() {
    ext="$1"
    php_loaded_extensions_list | grep -Fxi "${ext}" >/dev/null 2>&1
}

ext_module_file_exists() {
    ext="$1"
    extdir="$(php_extension_dir)"
    [ -n "${extdir}" ] && [ -f "${extdir}/${ext}.so" ]
}

ext_is_available() {
    ext="$1"
    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        return 0
    fi
    if ext_module_file_exists "${ext}"; then
        return 0
    fi
    return 1
}

ext_core_dir() {
    printf '%s\n' "${PHP_SRC_DIR}/ext/$1"
}

ext_is_known_core() {
    case "$1" in
        bcmath|bz2|calendar|ctype|curl|dba|dom|enchant|exif|ffi|fileinfo|ftp|gd|gettext|gmp|iconv|imap|intl|ldap|mbstring|mysqli|opcache|pcntl|pdo|pdo_mysql|pdo_pgsql|pdo_sqlite|pgsql|phar|posix|shmop|simplexml|snmp|soap|sockets|sodium|sysvmsg|sysvsem|sysvshm|tidy|tokenizer|xml|xmlreader|xmlwriter|xsl|zip)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

ext_detect_type_value() {
    ext="$1"

    if [ -d "$(ext_core_dir "${ext}")" ]; then
        printf '%s\n' "core"
        return 0
    fi

    if ext_is_known_core "${ext}"; then
        if [ -f /usr/src/php.tar.xz ] || cmd_exists docker-php-source; then
            printf '%s\n' "core-known-but-source-not-extracted"
            return 0
        fi
        printf '%s\n' "core-known-but-source-missing"
        return 0
    fi

    if cmd_exists "${PECL_BIN}" && "${PECL_BIN}" remote-info "${ext}" >/dev/null 2>&1; then
        printf '%s\n' "pecl"
        return 0
    fi

    printf '%s\n' "unknown"
    return 1
}

ext_already_present() {
    ext="$1"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        return 0
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        return 0
    fi

    if ext_module_file_exists "${ext}"; then
        return 0
    fi

    if ext_is_loaded "${ext}"; then
        return 0
    fi

    return 1
}

collect_ext_row() {
    ext="$1"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${ext}" "${avail}" "${active}" "${loaded}" "${version}" "$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)" "${available_ini}" "${active_ini}"
}

ext_ini_basename() {
    ext="$1"
    ini_name="$2"
    if [ -n "${ini_name}" ]; then
        case "${ini_name}" in
            *.ini) printf '%s\n' "${ini_name}" ;;
            *) printf '%s.ini\n' "${ini_name}" ;;
        esac
    else
        printf 'docker-php-ext-%s.ini\n' "${ext}"
    fi
}

ext_is_zend_extension() {
    module_path="$1"
    if cmd_exists "${READ_ELF_BIN}"; then
        "${READ_ELF_BIN}" --wide --syms "${module_path}" 2>/dev/null | grep -q ' zend_extension_entry$'
        return $?
    fi
    return 1
}

ext_write_ini() {
    ext="$1"
    module_name="$2"
    ini_name="$3"
    mkdir -p "${PHP_EXT_AVAILABLE_DIR}"
    ini_path="${PHP_EXT_AVAILABLE_DIR}/$(ext_ini_basename "${ext}" "${ini_name}")"
    if ext_is_zend_extension "$(php_extension_dir)/${module_name}.so"; then
        line="zend_extension=${module_name}"
    else
        line="extension=${module_name}"
    fi
    printf '%s\n' "${line}" > "${ini_path}"
    printf '%s\n' "${ini_path}"
}

php_source_prepare() {
    src_exists=""
    if [ -d "${PHP_SRC_DIR}" ]; then
        src_exists="1"
    fi

    cmd_exists docker-php-source || die "docker-php-source command not found"
    docker-php-source extract

    if [ -z "${src_exists}" ]; then
        touch "${PHP_SRC_DIR}/.docker-delete-me"
    fi
}

php_source_cleanup() {
    if [ -e "${PHP_SRC_DIR}/.docker-delete-me" ]; then
        cmd_exists docker-php-source || die "docker-php-source command not found"
        docker-php-source delete
    fi
}

ext_detect() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext detect <ext>"
    ext="$1"

    detected="$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)"
    buildable="no"
    installable="no"

    case "${detected}" in
        core|pecl|core-known-but-source-not-extracted)
            installable="yes"
            ;;
    esac

    case "${detected}" in
        core|core-known-but-source-not-extracted)
            buildable="yes"
            ;;
    esac

    emit_object <<EOF
name=${ext}
type=${detected}
buildable=${buildable}
installable=${installable}
core_dir=$(ext_core_dir "${ext}")
known_core=$(ext_is_known_core "${ext}" && printf yes || printf no)
source_present=$( [ -d "$(ext_core_dir "${ext}")" ] && printf yes || printf no )
already_present=$(ext_already_present "${ext}" && printf yes || printf no)
loaded=$(ext_is_loaded "${ext}" && printf yes || printf no)
module_file_exists=$(ext_module_file_exists "${ext}" && printf yes || printf no)
EOF
}

ext_install_core() {
    ext="$1"
    jobs="$2"
    enable_after="$3"
    no_cleanup="$4"
    ini_name="$5"
    apk_deps="$6"
    runtime_pkgs="$7"
    configure_args_file="$8"

    core_cleanup_done="no"

    cleanup_core_install() {
        [ "${core_cleanup_done}" = "yes" ] && return 0
        core_cleanup_done="yes"
        php_source_cleanup
        if [ "${no_cleanup}" != "yes" ]; then
            php_build_deps_cleanup
        fi
    }

    if [ -n "${runtime_pkgs}" ]; then
        apk_add_if_any ${runtime_pkgs}
    fi

    php_build_deps_install

    if [ -n "${apk_deps}" ]; then
        apk_add_if_any ${apk_deps}
    fi

    php_source_prepare
    trap cleanup_core_install EXIT INT TERM

    core_dir="$(ext_core_dir "${ext}")"
    [ -d "${core_dir}" ] || die "Core extension source directory not found: ${core_dir}"

    oldpwd="$(pwd)"
    cd "${core_dir}"

    : "${CFLAGS:=${PHP_CFLAGS:-}}"
    : "${CPPFLAGS:=${PHP_CPPFLAGS:-}}"
    : "${LDFLAGS:=${PHP_LDFLAGS:-}}"
    export CFLAGS CPPFLAGS LDFLAGS

    if [ ! -f configure ]; then
        "${PHPIZE_BIN}"
    fi

    if [ -s "${configure_args_file}" ]; then
        set --
        while IFS= read -r arg; do
            [ -n "${arg}" ] || continue
            set -- "$@" "${arg}"
        done < "${configure_args_file}"
        ./configure --enable-option-checking=fatal "$@"
    else
        ./configure --enable-option-checking=fatal
    fi

    "${MAKE_BIN}" -j"${jobs}"

    if ! "${PHP_BIN}" -n -d 'display_errors=stderr' -r 'exit(ZEND_DEBUG_BUILD ? 0 : 1);' >/dev/null 2>&1; then
        find modules \
            -maxdepth 1 \
            -name '*.so' \
            -exec sh -eu -c '
                if command -v "'"${STRIP_BIN}"'" >/dev/null 2>&1; then
                    "'"${STRIP_BIN}"'" --strip-all "$@" || :
                fi
            ' sh '{}' +
    fi

    "${MAKE_BIN}" install
    "${MAKE_BIN}" clean >/dev/null 2>&1 || true

    cd "${oldpwd}"

    [ -f "$(php_extension_dir)/${ext}.so" ] || die "Installed module file not found for: ${ext}"

    available_ini="$(ext_write_ini "${ext}" "${ext}" "${ini_name}")"

    if [ "${enable_after}" = "yes" ]; then
        mkdir -p "${PHP_EXT_ACTIVE_DIR}"
        ln -sf "${available_ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
    fi

    trap - EXIT INT TERM
    cleanup_core_install
}

ext_install_pecl() {
    ext="$1"
    version="$2"
    enable_after="$3"
    no_cleanup="$4"
    ini_name="$5"
    apk_deps="$6"
    runtime_pkgs="$7"

    cleanup_pecl_install() {
        if [ "${no_cleanup}" != "yes" ]; then
            php_build_deps_cleanup
        fi
    }

    cmd_exists "${PECL_BIN}" || die "pecl binary not found"

    if [ -n "${runtime_pkgs}" ]; then
        apk_add_if_any ${runtime_pkgs}
    fi

    php_build_deps_install

    if [ -n "${apk_deps}" ]; then
        apk_add_if_any ${apk_deps}
    fi

    trap cleanup_pecl_install EXIT INT TERM

    package="${ext}"
    if [ -n "${version}" ]; then
        package="${ext}-${version}"
    fi

    "${PECL_BIN}" channel-update pecl.php.net >/dev/null 2>&1 || true
    yes '' | "${PECL_BIN}" install "${package}" >/dev/null

    [ -f "$(php_extension_dir)/${ext}.so" ] || die "Installed module file not found for: ${ext}"

    available_ini="$(ext_write_ini "${ext}" "${ext}" "${ini_name}")"

    if [ "${enable_after}" = "yes" ]; then
        mkdir -p "${PHP_EXT_ACTIVE_DIR}"
        ln -sf "${available_ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
    fi

    trap - EXIT INT TERM
    cleanup_pecl_install
}

machine_id_value() {
    if [ -f /etc/machine-id ]; then
        sed -n '1p' /etc/machine-id | tr -d '\r\n'
        return 0
    fi
    if [ -f /var/lib/dbus/machine-id ]; then
        sed -n '1p' /var/lib/dbus/machine-id | tr -d '\r\n'
        return 0
    fi
    printf '%s\n' "-"
}

worker_detect_id() {
    if [ -n "${PHPCTL_WORKER_ID}" ]; then
        printf '%s\n' "${PHPCTL_WORKER_ID}"
        return 0
    fi
    hostname 2>/dev/null || printf '%s\n' "unknown"
}

worker_detect_group() {
    if [ -n "${PHPCTL_WORKER_GROUP}" ]; then
        printf '%s\n' "${PHPCTL_WORKER_GROUP}"
        return 0
    fi
    printf '%s\n' "-"
}

worker_labels_json() {
    labels_file="$(mktemp_file)"
    : > "${labels_file}"

    if [ -n "${PHPCTL_WORKER_LABELS_JSON}" ]; then
        PHPCTL_LABELS_JSON_INPUT="${PHPCTL_WORKER_LABELS_JSON}" "${PHP_BIN}" -r '
            $json = getenv("PHPCTL_LABELS_JSON_INPUT");
            $obj = json_decode((string) $json, true);
            if (is_array($obj)) {
                foreach ($obj as $k => $v) {
                    if (is_scalar($v) || $v === null) {
                        echo (string) $k, "\t", (string) $v, PHP_EOL;
                    }
                }
            }
        ' >> "${labels_file}" 2>/dev/null || true
    fi

    env | awk -F '=' '
        index($1, "PHPCTL_WORKER_LABEL_") == 1 {
            key = substr($1, length("PHPCTL_WORKER_LABEL_") + 1)
            value = substr($0, length($1) + 2)
            gsub(/__/, "-", key)
            key = tolower(key)
            gsub(/_/, "-", key)
            print key "\t" value
        }
    ' >> "${labels_file}" 2>/dev/null || true

    WORKER_LABELS_FILE="${labels_file}" "${PHP_BIN}" -r '
        $file = getenv("WORKER_LABELS_FILE");
        $out = [];
        foreach (@file($file, FILE_IGNORE_NEW_LINES) ?: [] as $line) {
            if ($line === "") {
                continue;
            }
            $parts = explode("\t", $line, 2);
            $key = $parts[0] ?? "";
            $value = $parts[1] ?? "";
            if ($key === "") {
                continue;
            }
            $out[$key] = $value;
        }
        ksort($out, SORT_NATURAL | SORT_FLAG_CASE);
        echo json_encode($out, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
    '
    rm -f "${labels_file}"
}

worker_usage_collect() {
    pool_count=0
    active_pool_count=0
    sum_pm_max_children=0

    if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
        pool_count="$(find "${PHP_FPM_POOL_AVAILABLE_DIR}" -maxdepth 1 -type f -name '*.conf' | wc -l | tr -d '[:space:]')"
    fi

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        active_pool_count="$(find "${PHP_FPM_POOL_ACTIVE_DIR}" -maxdepth 1 \( -type f -o -type l \) -name '*.conf' | wc -l | tr -d '[:space:]')"
        find "${PHP_FPM_POOL_ACTIVE_DIR}" -maxdepth 1 \( -type f -o -type l \) -name '*.conf' | while IFS= read -r pool_file; do
            v="$(pool_config_get_value "${pool_file}" "pm.max_children" || true)"
            case "${v:-}" in
                ''|*[!0-9]*) printf '0\n' ;;
                *) printf '%s\n' "${v}" ;;
            esac
        done > "${PHP_FPM_POOL_ACTIVE_DIR}/.phpctl_pm_max_children.tmp.$$" 2>/dev/null || true
        if [ -f "${PHP_FPM_POOL_ACTIVE_DIR}/.phpctl_pm_max_children.tmp.$$" ]; then
            sum_pm_max_children="$(awk '{ s += $1 } END { print s+0 }' "${PHP_FPM_POOL_ACTIVE_DIR}/.phpctl_pm_max_children.tmp.$$")"
            rm -f "${PHP_FPM_POOL_ACTIVE_DIR}/.phpctl_pm_max_children.tmp.$$"
        fi
    fi

    replicas="${active_pool_count}"

    printf 'pool_count=%s\n' "${pool_count}"
    printf 'active_pool_count=%s\n' "${active_pool_count}"
    printf 'sum_pm_max_children=%s\n' "${sum_pm_max_children}"
    printf 'replicas=%s\n' "${replicas}"
}

