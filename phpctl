pool_params_set() {
    file="$1"
    key="$2"
    value="$3"
    tmp="$(mktemp_file)"
    if [ -f "${file}" ]; then
        awk -F '=' -v k="${key}" '$1 != k { print }' "${file}" > "${tmp}" || true
    else
        : > "${tmp}"
    fi
    printf '%s=%s\n' "${key}" "${value}" >> "${tmp}"
    mv "${tmp}" "${file}"
}

pool_params_load_file() {
    dst="$1"
    src="$2"
    [ -f "${src}" ] || die "Params file not found: ${src}"
    while IFS= read -r line; do
        [ -n "${line}" ] || continue
        case "${line}" in
            \#*) continue ;;
        esac
        key="${line%%=*}"
        value="${line#*=}"
        [ "${key}" != "${line}" ] || continue
        pool_params_set "${dst}" "${key}" "${value}"
    done < "${src}"
}

fpm_pool_build_params() {
    name="$1"

    params_file="$(mktemp_file)"
    : > "${params_file}"

    pool_params_set "${params_file}" "POOL_NAME" "${name}"
    pool_params_set "${params_file}" "USER" "www-data"
    pool_params_set "${params_file}" "GROUP" "www-data"
    pool_params_set "${params_file}" "LISTEN" "/var/run/php-fpm-${name}.sock"
    pool_params_set "${params_file}" "LISTEN_OWNER" "www-data"
    pool_params_set "${params_file}" "LISTEN_GROUP" "www-data"
    pool_params_set "${params_file}" "PM" "dynamic"
    pool_params_set "${params_file}" "PM_MAX_CHILDREN" "8"
    pool_params_set "${params_file}" "PM_START_SERVERS" "2"
    pool_params_set "${params_file}" "PM_MIN_SPARE_SERVERS" "1"
    pool_params_set "${params_file}" "PM_MAX_SPARE_SERVERS" "3"
    pool_params_set "${params_file}" "CATCH_WORKERS_OUTPUT" "yes"
    pool_params_set "${params_file}" "CLEAR_ENV" "no"
    pool_params_set "${params_file}" "ENABLE_METRICS" "false"
    pool_params_set "${params_file}" "STATUS_PATH" ""
    pool_params_set "${params_file}" "ENABLE_PING" "false"
    pool_params_set "${params_file}" "PING_PATH" ""
    pool_params_set "${params_file}" "PING_RESPONSE" ""

    printf '%s\n' "${params_file}"
}

fpm_pool_render_content() {
    name="$1"
    template_file="$2"
    params_file="$3"

    render_template="$(mktemp_file)"
    if [ -n "${template_file}" ]; then
        [ -f "${template_file}" ] || die "Template not found: ${template_file}"
        cat "${template_file}" > "${render_template}"
    elif [ -n "${PHP_FPM_POOL_TEMPLATE}" ]; then
        [ -f "${PHP_FPM_POOL_TEMPLATE}" ] || die "Template not found: ${PHP_FPM_POOL_TEMPLATE}"
        cat "${PHP_FPM_POOL_TEMPLATE}" > "${render_template}"
    else
        fpm_default_pool_template > "${render_template}"
    fi

    PHPCTL_TEMPLATE_FILE="${render_template}" PHPCTL_PARAMS_FILE="${params_file}" "${PHP_BIN}" -r '
        function loadParams(string $file): array {
            $params = [];
            foreach (@file($file, FILE_IGNORE_NEW_LINES) ?: [] as $line) {
                if ($line === "" || strpos($line, "#") === 0) {
                    continue;
                }
                $parts = explode("=", $line, 2);
                if (count($parts) === 2) {
                    $params[$parts[0]] = $parts[1];
                }
            }
            return $params;
        }

        function isTrueValue($value): bool {
            $v = strtolower(trim((string) $value));
            return in_array($v, ["1", "true", "yes", "on"], true);
        }

        function isEmptyValue($value): bool {
            return trim((string) $value) === "";
        }

        function evalIfExpr(string $expr, array $params): bool {
            $expr = trim($expr);

            if (preg_match("/^empty\\s+([A-Z0-9_]+)$/i", $expr, $m)) {
                $key = $m[1];
                return isEmptyValue($params[$key] ?? "");
            }

            if (preg_match("/^not\\s+empty\\s+([A-Z0-9_]+)$/i", $expr, $m)) {
                $key = $m[1];
                return !isEmptyValue($params[$key] ?? "");
            }

            if (preg_match("/^([A-Z0-9_]+)\\s*==\\s*(.+)$/i", $expr, $m)) {
                $key = $m[1];
                $expected = trim($m[2]);
                $expected = preg_replace("/^\"(.*)\"$/", "$1", $expected);
                $expected = preg_replace("/^\x27(.*)\x27$/", "$1", $expected);
                return (string) ($params[$key] ?? "") === $expected;
            }

            if (preg_match("/^([A-Z0-9_]+)\\s*!=\\s*(.+)$/i", $expr, $m)) {
                $key = $m[1];
                $expected = trim($m[2]);
                $expected = preg_replace("/^\"(.*)\"$/", "$1", $expected);
                $expected = preg_replace("/^\x27(.*)\x27$/", "$1", $expected);
                return (string) ($params[$key] ?? "") !== $expected;
            }

            if (preg_match("/^([A-Z0-9_]+)$/i", $expr, $m)) {
                $key = $m[1];
                return isTrueValue($params[$key] ?? "");
            }

            return false;
        }

        function renderVars(string $text, array $params): string {
            return preg_replace_callback("/\\{\\{\\s*([A-Z0-9_]+)(?:\\s*\\|\\s*default\\((.*?)\\))?\\s*\\}\\}/i", function ($m) use ($params) {
                $key = $m[1];
                $value = $params[$key] ?? "";
                if (isset($m[2])) {
                    $default = trim($m[2]);
                    $default = preg_replace("/^\"(.*)\"$/", "$1", $default);
                    $default = preg_replace("/^\x27(.*)\x27$/", "$1", $default);
                    if (trim((string) $value) === "") {
                        $value = $default;
                    }
                }
                return (string) $value;
            }, $text);
        }

        function renderTemplate(string $template, array $params): string {
            $lines = preg_split("/\\r?\\n/", $template);
            $out = [];
            $stack = [true];

            foreach ($lines as $line) {
                if (preg_match("/^\\s*\\{\\{\\s*if\\s+(.+?)\\s*\\}\\}\\s*$/", $line, $m)) {
                    $parent = end($stack);
                    $stack[] = $parent && evalIfExpr($m[1], $params);
                    continue;
                }

                if (preg_match("/^\\s*\\{\\{\\s*endif\\s*\\}\\}\\s*$/", $line)) {
                    if (count($stack) > 1) {
                        array_pop($stack);
                    }
                    continue;
                }

                if (end($stack)) {
                    $out[] = renderVars($line, $params);
                }
            }

            return implode(PHP_EOL, $out) . PHP_EOL;
        }

        $template = file_get_contents(getenv("PHPCTL_TEMPLATE_FILE"));
        $params = loadParams(getenv("PHPCTL_PARAMS_FILE"));
        echo renderTemplate($template, $params);
    '
    rm -f "${render_template}"
}

