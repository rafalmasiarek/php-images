        status)
            shift
            fpm_status "$@"
            ;;
        test)
            shift
            fpm_test "$@"
            ;;
        configtest)
            shift
            fpm_test "$@"
            ;;
        reload)
            shift
            fpm_reload "$@"
            ;;
        capacity)
            shift
            fpm_capacity "$@"
            ;;
        pool)
            shift
            [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool <list|render|create|upsert|generate|import|bundle|enable|disable|delete|content|validate|show> ..."
            case "$1" in
                help|--help|-h)
                    fpm_usage
                    ;;
                list)
                    shift
                    fpm_pool_list "$@"
                    ;;
                render)
                    shift
                    fpm_pool_render "$@"
                    ;;
                create)
                    shift
                    fpm_pool_create "$@"
                    ;;
                upsert)
                    shift
                    fpm_pool_upsert "$@"
                    ;;
                generate)
                    shift
                    fpm_pool_generate "$@"
                    ;;
                import)
                    shift
                    fpm_pool_import "$@"
                    ;;
                bundle)
                    shift
                    [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool bundle import ..."
                    case "$1" in
                        import)
                            shift
                            fpm_pool_bundle_import "$@"
                            ;;
                        *)
                            die "Unknown fpm pool bundle subcommand: $1"
                            ;;
                    esac
                    ;;
                enable)
                    shift
                    fpm_pool_enable "$@"
                    ;;
                disable)
                    shift
                    fpm_pool_disable "$@"
                    ;;
                delete)
                    shift
                    fpm_pool_delete "$@"
                    ;;
