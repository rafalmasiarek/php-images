ext_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ext <subcommand> [args]

Subcommands:
  list                 List discovered extensions
  list-loaded          List loaded extensions
  versions             Show loaded extensions with versions
  detect <ext>         Detect extension type
  pecl-list            Show PECL registry packages
  so-list              Show extension directory shared objects
