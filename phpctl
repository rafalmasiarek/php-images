ext_list() {
    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        for f in "${PHP_EXT_AVAILABLE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ext_name_from_ini "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        for f in "${PHP_EXT_ACTIVE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ext_name_from_ini "${f}" >> "${tmp_names}"
        done
    fi

    php_loaded_extensions_list >> "${tmp_names}"

    printf 'name\tavailable\tactive\tloaded\tversion\ttype\tavailable_ini\tactive_ini\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r ext; do
            [ -n "${ext}" ] || continue
            collect_ext_row "${ext}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"

    rm -f "${tmp_names}" "${tmp_rows}"
}

ext_list_loaded() {
    tmp="$(mktemp_file)"
    printf 'name\n' > "${tmp}"
    php_loaded_extensions_list | while IFS= read -r ext; do
        [ -n "${ext}" ] || continue
        printf '%s\n' "${ext}"
    done >> "${tmp}"
    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_versions() {
    tmp="$(mktemp_file)"
    printf 'name\tversion\n' > "${tmp}"
    php_loaded_extensions_list | while IFS= read -r ext; do
        [ -n "${ext}" ] || continue
        printf '%s\t%s\n' "${ext}" "$(php_ext_version "${ext}")"
    done >> "${tmp}"
    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_pecl_list() {
    tmp="$(mktemp_file)"
    printf 'name\tversion\tstate\n' > "${tmp}"

    if cmd_exists "${PECL_BIN}"; then
        "${PECL_BIN}" list 2>/dev/null | awk '
            BEGIN { capture=0 }
            /^Package[[:space:]]+Version[[:space:]]+State/ { capture=1; next }
            /^=+/ { next }
            capture == 1 && NF >= 3 { print $1 "\t" $2 "\t" $3 }
        ' >> "${tmp}" || true
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_so_list() {
    tmp="$(mktemp_file)"
    extdir="$(php_extension_dir)"
    printf 'name\tpath\tsize\n' > "${tmp}"

    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        find "${extdir}" -maxdepth 1 -type f -name '*.so' | sort | while IFS= read -r sofile; do
            [ -n "${sofile}" ] || continue
            name="$(basename "${sofile}" .so)"
            size="$(wc -c < "${sofile}" | tr -d '[:space:]')"
            printf '%s\t%s\t%s\n' "${name}" "${sofile}" "${size}"
        done >> "${tmp}"
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_status() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext status <ext>"
    ext="$1"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    emit_object <<EOF
name=${ext}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
type=$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)
available_ini=${available_ini}
active_ini=${active_ini}
extension_dir=$(php_extension_dir)
EOF
}

ext_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext enable <ext>"
    ext="$1"
    ini="$(resolve_ext_ini "${ext}" 2>/dev/null || true)"

    [ -n "${ini}" ] || die "No available ini found for extension: ${ext}"

    mkdir -p "${PHP_EXT_ACTIVE_DIR}"
    ln -sf "${ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${ini}")"

    emit_object <<EOF
ok=yes
action=enable
extension=${ext}
active=yes
active_ini=${PHP_EXT_ACTIVE_DIR}/$(basename "${ini}")
EOF
}

ext_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext disable <ext>"
    ext="$1"

    removed="no"
    removed_ini="-"

    for candidate in \
        "${PHP_EXT_ACTIVE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/zz-${ext}.ini"
    do
        if [ -e "${candidate}" ]; then
            rm -f "${candidate}"
            removed="yes"
            removed_ini="${candidate}"
        fi
    done

    emit_object <<EOF
ok=yes
action=disable
extension=${ext}
removed=${removed}
removed_ini=${removed_ini}
EOF
}

ext_enable_all() {
    mkdir -p "${PHP_EXT_ACTIVE_DIR}"
    tmp="$(mktemp_file)"
    printf 'name\tresult\tactive_ini\n' > "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        for f in "${PHP_EXT_AVAILABLE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            ln -sf "${f}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${f}")"
            printf '%s\tenabled\t%s\n' "$(ext_name_from_ini "${f}")" "${PHP_EXT_ACTIVE_DIR}/$(basename "${f}")" >> "${tmp}"
        done
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_disable_all() {
    tmp="$(mktemp_file)"
    printf 'name\tresult\tactive_ini\n' > "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        for f in "${PHP_EXT_ACTIVE_DIR}"/*.ini; do
            [ -e "${f}" ] || continue
            printf '%s\tdisabled\t%s\n' "$(ext_name_from_ini "${f}")" "${f}" >> "${tmp}"
            rm -f "${f}"
        done
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_doctor() {
    tmp="$(mktemp_file)"
    printf 'check\tstatus\tdetails\n' > "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        s1="ok"
        d1="${PHP_EXT_AVAILABLE_DIR}"
    else
        s1="warn"
        d1="missing: ${PHP_EXT_AVAILABLE_DIR}"
    fi
    printf 'available_dir\t%s\t%s\n' "${s1}" "${d1}" >> "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        s2="ok"
        d2="${PHP_EXT_ACTIVE_DIR}"
    else
        s2="warn"
        d2="missing: ${PHP_EXT_ACTIVE_DIR}"
    fi
    printf 'active_dir\t%s\t%s\n' "${s2}" "${d2}" >> "${tmp}"

    extdir="$(php_extension_dir)"
    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        s3="ok"
        d3="${extdir}"
    else
        s3="warn"
        d3="${extdir:-extension_dir missing}"
    fi
    printf 'extension_dir\t%s\t%s\n' "${s3}" "${d3}" >> "${tmp}"

    if [ -d "${PHP_SRC_DIR}" ]; then
        s4="ok"
        d4="${PHP_SRC_DIR}"
    else
        s4="warn"
        d4="missing: ${PHP_SRC_DIR}"
    fi
    printf 'php_src_dir\t%s\t%s\n' "${s4}" "${d4}" >> "${tmp}"

    loaded_count="$(php_loaded_extensions_list | awk 'NF { c++ } END { print c+0 }')"
    printf 'loaded_extensions\tok\t%s\n' "${loaded_count}" >> "${tmp}"

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

ext_install_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ext install <ext> [options]

Options:
  --type <auto|core|pecl> Detect or force extension source type
  --enable                 Enable extension after successful install
  --version <ver>          Install a specific PECL version
  --apk <pkgs...>          Additional build dependencies installed via apk
  --runtime <pkgs...>      Additional runtime packages installed via apk
  --jobs <n>               Build jobs for core extensions
  --configure <arg>        Add configure arg for core extension build
  --ini-name <name>        Override generated ini file name
  --force                  Reinstall even if extension appears installed
  --no-cleanup             Do not remove temporary build dependencies
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ext_install
usage=${PROG} ext install <ext> [options]
options=--type,--enable,--version,--apk,--runtime,--jobs,--configure,--ini-name,--force,--no-cleanup
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ext_install() {
    [ $# -gt 0 ] || die "Usage: ${PROG} ext install <ext> [options]"

    ext="$1"
    shift

    type="auto"
    enable_after="no"
    pecl_version=""
    apk_deps=""
    runtime_pkgs=""
    jobs="1"
    ini_name=""
    force="no"
    no_cleanup="no"
    configure_args_file="$(mktemp_file)"
    : > "${configure_args_file}"

    while [ $# -gt 0 ]; do
        case "$1" in
            --type)
                shift
                [ $# -gt 0 ] || die "Missing value for --type"
                case "$1" in
                    auto|core|pecl) type="$1" ;;
                    *) rm -f "${configure_args_file}"; die "Unsupported extension type: $1" ;;
                esac
                shift
                ;;
            --enable)
                enable_after="yes"
                shift
                ;;
            --version)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --version"; }
                pecl_version="$1"
                shift
                ;;
            --apk)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    apk_deps="${apk_deps} $1"
                    shift
                done
                ;;
            --runtime)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    runtime_pkgs="${runtime_pkgs} $1"
                    shift
                done
                ;;
            --jobs)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --jobs"; }
                jobs="$1"
                shift
                ;;
            --configure)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --configure"; }
                printf '%s\n' "$1" >> "${configure_args_file}"
                shift
                ;;
            --ini-name)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --ini-name"; }
                ini_name="$1"
                shift
                ;;
            --force)
                force="yes"
                shift
                ;;
            --no-cleanup)
                no_cleanup="yes"
                shift
                ;;
            -h|--help)
                rm -f "${configure_args_file}"
                ext_install_usage
                return 0
                ;;
            *)
                rm -f "${configure_args_file}"
                die "Unknown install option: $1"
                ;;
        esac
    done

    if [ "${force}" != "yes" ]; then
        if ext_is_available "${ext}" || resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
            rm -f "${configure_args_file}"
            die "Extension already appears installed: ${ext}. Use --force to reinstall."
        fi
    fi

    if [ "${type}" = "auto" ]; then
        detected="$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)"
        case "${detected}" in
            core) type="core" ;;
            pecl) type="pecl" ;;
            core-known-but-source-missing)
                rm -f "${configure_args_file}"
                die "Extension looks like a core extension but PHP source tree is missing: ${ext}"
                ;;
            *)
                rm -f "${configure_args_file}"
                die "Unable to detect extension type for: ${ext}"
                ;;
        esac
    fi

    if [ "${type}" = "core" ] && [ -n "${pecl_version}" ]; then
        rm -f "${configure_args_file}"
        die "--version is only supported for PECL extensions"
    fi

    if [ "${type}" = "pecl" ]; then
        ext_install_pecl "${ext}" "${pecl_version}" "${enable_after}" "${no_cleanup}" "${ini_name}" "${apk_deps# }" "${runtime_pkgs# }"
        package="${ext}"
        if [ -n "${pecl_version}" ]; then
            package="${ext}-${pecl_version}"
        fi
    else
        ext_install_core "${ext}" "${jobs}" "${enable_after}" "${no_cleanup}" "${ini_name}" "${apk_deps# }" "${runtime_pkgs# }" "${configure_args_file}"
        package="${ext}"
    fi

    rm -f "${configure_args_file}"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    emit_object <<EOF
ok=yes
action=install
extension=${ext}
type=${type}
requested_package=${package}
enabled=${enable_after}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
available_ini=${available_ini}
active_ini=${active_ini}
