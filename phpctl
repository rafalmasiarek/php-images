pool_name_from_path() {
    base="$(basename "$1")"
    base="${base%.pool.conf}"
    base="${base%.conf}"
    printf '%s\n' "${base}"
}

pool_config_get_value() {
    file="$1"
    key="$2"
    awk -F '=' -v key="${key}" '
        $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
            v=$0
            sub(/^[^=]*=[[:space:]]*/, "", v)
            sub(/[[:space:]]+$/, "", v)
            print v
            exit
        }
    ' "${file}" 2>/dev/null || true
}

show_metrics_text() {
    php_up=0
    fpm_up=0
    fpm_config_valid=0

    if cmd_exists "${PHP_BIN}" && "${PHP_BIN}" -v >/dev/null 2>&1; then
        php_up=1
    fi

    if cmd_exists "${PHP_FPM_BIN}"; then
        pid="$(php_fpm_master_pid 2>/dev/null || true)"
        if [ -n "${pid}" ] && kill -0 "${pid}" >/dev/null 2>&1; then
            fpm_up=1
        fi
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            fpm_config_valid=1
        fi
    fi

    loaded_ext_count="$(php_loaded_extensions_list | awk 'NF { c++ } END { print c+0 }')"
    pools_available="0"
    pools_enabled="0"

    [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ] && pools_available="$(find "${PHP_FPM_POOL_AVAILABLE_DIR}" -maxdepth 1 -type f -name '*.conf' | wc -l | tr -d '[:space:]')"
    [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ] && pools_enabled="$(find "${PHP_FPM_POOL_ACTIVE_DIR}" -maxdepth 1 \( -type f -o -type l \) -name '*.conf' | wc -l | tr -d '[:space:]')"

    printf '%s\n' '# HELP phpctl_php_up PHP CLI availability'
    printf '%s\n' '# TYPE phpctl_php_up gauge'
    printf 'phpctl_php_up %s\n' "${php_up}"

    printf '%s\n' '# HELP phpctl_fpm_up PHP-FPM master process availability'
    printf '%s\n' '# TYPE phpctl_fpm_up gauge'
    printf 'phpctl_fpm_up %s\n' "${fpm_up}"

    printf '%s\n' '# HELP phpctl_fpm_config_valid PHP-FPM configuration validity'
    printf '%s\n' '# TYPE phpctl_fpm_config_valid gauge'
    printf 'phpctl_fpm_config_valid %s\n' "${fpm_config_valid}"

    printf '%s\n' '# HELP phpctl_extensions_loaded Number of loaded PHP extensions'
    printf '%s\n' '# TYPE phpctl_extensions_loaded gauge'
    printf 'phpctl_extensions_loaded %s\n' "${loaded_ext_count}"

    printf '%s\n' '# HELP phpctl_fpm_pools_available Number of available FPM pools'
    printf '%s\n' '# TYPE phpctl_fpm_pools_available gauge'
    printf 'phpctl_fpm_pools_available %s\n' "${pools_available}"

    printf '%s\n' '# HELP phpctl_fpm_pools_enabled Number of enabled FPM pools'
    printf '%s\n' '# TYPE phpctl_fpm_pools_enabled gauge'
    printf 'phpctl_fpm_pools_enabled %s\n' "${pools_enabled}"

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        find "${PHP_FPM_POOL_ACTIVE_DIR}" -maxdepth 1 \( -type f -o -type l \) -name '*.conf' | sort | while IFS= read -r pool_file; do
            pool_name="$(pool_name_from_path "${pool_file}")"
            listen_value="$(pool_config_get_value "${pool_file}" listen)"
            socket_exists=0
            if [ -n "${listen_value}" ]; then
                case "${listen_value}" in
                    /*) [ -S "${listen_value}" ] && socket_exists=1 ;;
                esac
            fi
            printf 'phpctl_fpm_pool_enabled{pool=%s} 1\n' "$(json_quote "${pool_name}")"
            printf 'phpctl_fpm_pool_socket_exists{pool=%s} %s\n' "$(json_quote "${pool_name}")" "${socket_exists}"
        done
    fi
}

