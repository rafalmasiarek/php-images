phpctl_is_unix_socket_endpoint() {
    case "$1" in
        /*) return 0 ;;
        *) return 1 ;;
    esac
}

nc_supports_unix_sockets() {
    "${NC_BIN}" 2>&1 | grep -q -- '-U'
}

nc_supports_exec() {
    "${NC_BIN}" 2>&1 | grep -q -- '-e '
}

phpctl_validate_endpoint() {
    endpoint="$1"

    if phpctl_is_unix_socket_endpoint "${endpoint}"; then
        return 0
    fi

    case "${endpoint}" in
        *:*)
            host_part="${endpoint%:*}"
            port_part="${endpoint##*:}"
            [ -n "${host_part}" ] || return 1
            [ -n "${port_part}" ] || return 1
            case "${port_part}" in
                *[!0-9]*|'')
                    return 1
                    ;;
            esac
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

http_extract_body() {
    src="$1"
    dst="$2"
    awk '
        BEGIN { body=0 }
        {
            line=$0
            sub(/\r$/, "", line)
            if (body) {
                print line
            } else if (line == "") {
                body=1
            }
        }
    ' "${src}" > "${dst}"
}

http_read_request_meta() {
    src="$1"
    meta="$2"
    awk '
        BEGIN {
            method=""
            path=""
            content_length="0"
            headers_done=0
        }
        NR == 1 {
            line=$0
            sub(/\r$/, "", line)
            split(line, p, " ")
            method=p[1]
            path=p[2]
            next
        }
        {
            line=$0
            sub(/\r$/, "", line)
            if (headers_done == 1) {
                next
            }
            if (line == "") {
                headers_done=1
                next
            }
            if (line ~ /^[Cc]ontent-[Ll]ength:[[:space:]]*/) {
                sub(/^[^:]*:[[:space:]]*/, "", line)
                gsub(/[[:space:]]/, "", line)
                content_length=line
            }
        }
        END {
            print "method=" method
            print "path=" path
            print "content_length=" content_length
        }
    ' "${src}" > "${meta}"
}

phpctl_client_load_config() {
    conf_file="$1"
    conf_host=""
    conf_user=""
    conf_password=""

    [ -f "${conf_file}" ] || return 0

    while IFS= read -r line; do
        [ -n "${line}" ] || continue
        case "${line}" in
            \#*) continue ;;
        esac
        key="${line%%=*}"
        value="${line#*=}"
        case "${key}" in
            host) conf_host="${value}" ;;
            user) conf_user="${value}" ;;
            password|pasword) conf_password="${value}" ;;
        esac
    done < "${conf_file}"

    [ -n "${PHPCTL_REMOTE_HOST}" ] || PHPCTL_REMOTE_HOST="${conf_host}"
    if [ -z "${PHPCTL_REMOTE_CREDENTIALS}" ] && [ -n "${conf_user}" ] && [ -n "${conf_password}" ]; then
        PHPCTL_REMOTE_CREDENTIALS="${conf_user}:${conf_password}"
    fi
}

phpctl_client_build_payload() {
    args_file="$(mktemp_file)"
    payload_file="$(mktemp_file)"
    : > "${args_file}"

    for arg in "$@"; do
        printf '%s\n' "${arg}" >> "${args_file}"
    done

    PHPCTL_ARGS_FILE="${args_file}" PHPCTL_PAYLOAD_FILE="${payload_file}" PHPCTL_OUTPUT_VALUE="${OUTPUT_FORMAT}" "${PHP_BIN}" -r '
        $args = file(getenv("PHPCTL_ARGS_FILE"), FILE_IGNORE_NEW_LINES) ?: [];
        $payload = [
            "argv" => array_values($args),
            "output" => getenv("PHPCTL_OUTPUT_VALUE") ?: "text",
        ];
        file_put_contents(getenv("PHPCTL_PAYLOAD_FILE"), json_encode($payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
    '

    rm -f "${args_file}"
    printf '%s\n' "${payload_file}"
}

phpctl_client_send_http() {
    host="$1"
    auth="$2"
    payload_file="$3"

    response_file="$(mktemp_file)"
    request_file="$(mktemp_file)"
    payload_len="$(wc -c < "${payload_file}" | tr -d '[:space:]')"
    auth_header=""

    if [ -n "${auth}" ]; then
        auth_value="$("${PHP_BIN}" -r 'echo base64_encode($argv[1]);' "${auth}")"
        auth_header="Authorization: Basic ${auth_value}\r\n"
    fi

    {
        printf 'POST /run HTTP/1.1\r\n'
        printf 'Host: phpctl\r\n'
        printf 'Content-Type: application/json\r\n'
        printf 'Content-Length: %s\r\n' "${payload_len}"
        printf '%b' "${auth_header}"
        printf 'Connection: close\r\n'
        printf '\r\n'
        cat "${payload_file}"
    } > "${request_file}"

    case "${host}" in
        /*)
            nc_supports_unix_sockets || {
                rm -f "${request_file}" "${response_file}"
                die "Current nc implementation does not support Unix sockets (-U missing)"
            }
            "${NC_BIN}" -U "${host}" < "${request_file}" > "${response_file}" 2>/dev/null || {
                rm -f "${request_file}" "${response_file}"
                die "Unable to connect to socket: ${host}"
            }
            ;;
        *)
            tcp_host="${host%:*}"
            tcp_port="${host##*:}"
            [ -n "${tcp_host}" ] || { rm -f "${request_file}" "${response_file}"; die "Invalid remote host: ${host}"; }
            [ -n "${tcp_port}" ] || { rm -f "${request_file}" "${response_file}"; die "Invalid remote host: ${host}"; }
            "${NC_BIN}" "${tcp_host}" "${tcp_port}" < "${request_file}" > "${response_file}" 2>/dev/null || {
                rm -f "${request_file}" "${response_file}"
                die "Unable to connect to host: ${host}"
            }
            ;;
    esac

    rm -f "${request_file}"
    printf '%s\n' "${response_file}"
}

phpctl_client_consume_response() {
    response_file="$1"
    body_file="$(mktemp_file)"

    http_extract_body "${response_file}" "${body_file}"

    PHPCTL_BODY_FILE="${body_file}" "${PHP_BIN}" -r '
        $body = file_get_contents(getenv("PHPCTL_BODY_FILE"));
        if ($body === false || trim($body) === "") {
            fwrite(STDERR, "Empty response body\n");
            exit(1);
        }

        $json = json_decode($body, true);
        if (!is_array($json)) {
            fwrite(STDERR, $body);
            exit(1);
        }

        $stdout = (string) ($json["stdout"] ?? "");
        $stderr = (string) ($json["stderr"] ?? "");
        $exitCode = (int) ($json["exit_code"] ?? 1);

        if ($stdout !== "") {
            fwrite(STDOUT, $stdout);
            if (substr($stdout, -1) !== "\n") {
                fwrite(STDOUT, "\n");
            }
        }

        if ($stderr !== "") {
            fwrite(STDERR, $stderr);
            if (substr($stderr, -1) !== "\n") {
                fwrite(STDERR, "\n");
            }
        }

        exit($exitCode);
    '
    rc=$?
    rm -f "${body_file}"
    return "${rc}"
}

phpctl_client_run() {
    host=""
    credentials=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --host)
                shift
                [ $# -gt 0 ] || die "Missing value for --host"
                host="$1"
                shift
                ;;
            --credentials)
                shift
                [ $# -gt 0 ] || die "Missing value for --credentials"
                credentials="$1"
                shift
                ;;
            -h|--help)
                client_usage
                return 0
                ;;
            *)
                break
                ;;
        esac
    done

    [ $# -gt 0 ] || die "Client requires a remote command"

    PHPCTL_REMOTE_HOST="${host}"
    PHPCTL_REMOTE_CREDENTIALS="${credentials}"
    phpctl_client_load_config "${PHPCTL_CLIENT_CONF}"

    [ -n "${PHPCTL_REMOTE_HOST}" ] || die "Remote host is not configured"
    phpctl_validate_endpoint "${PHPCTL_REMOTE_HOST}" || die "Invalid remote host: ${PHPCTL_REMOTE_HOST}"

    payload_file="$(phpctl_client_build_payload "$@")"
    response_file="$(phpctl_client_send_http "${PHPCTL_REMOTE_HOST}" "${PHPCTL_REMOTE_CREDENTIALS}" "${payload_file}")"
    rm -f "${payload_file}"

    phpctl_client_consume_response "${response_file}"
    rc=$?
    rm -f "${response_file}"
    return "${rc}"
}

phpctl_server_run_payload() {
    body_file="$1"
    result_file="$2"

    PHPCTL_BODY_FILE="${body_file}" PHPCTL_RESULT_FILE="${result_file}" PHPCTL_SELF_PATH="${SELF_PATH}" "${PHP_BIN}" -r '
        $body = file_get_contents(getenv("PHPCTL_BODY_FILE"));
        $data = json_decode((string) $body, true);

        if (!is_array($data)) {
            file_put_contents(getenv("PHPCTL_RESULT_FILE"), json_encode([
                "ok" => false,
                "exit_code" => 1,
                "stdout" => "",
                "stderr" => "Invalid JSON payload",
            ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
            exit(0);
        }

        $argv = $data["argv"] ?? [];
        if (!is_array($argv)) {
            $argv = [];
        }

        $output = (string) ($data["output"] ?? "text");

        $cmd = [getenv("PHPCTL_SELF_PATH"), "--output", $output];
        foreach ($argv as $arg) {
            $cmd[] = (string) $arg;
        }

        $descriptors = [
            0 => ["pipe", "r"],
            1 => ["pipe", "w"],
            2 => ["pipe", "w"],
        ];

        $proc = proc_open($cmd, $descriptors, $pipes);
        if (!is_resource($proc)) {
            file_put_contents(getenv("PHPCTL_RESULT_FILE"), json_encode([
                "ok" => false,
                "exit_code" => 1,
                "stdout" => "",
                "stderr" => "Unable to spawn phpctl command",
            ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
            exit(0);
        }

        fclose($pipes[0]);
        $stdout = stream_get_contents($pipes[1]);
        $stderr = stream_get_contents($pipes[2]);
        fclose($pipes[1]);
        fclose($pipes[2]);
        $exitCode = proc_close($proc);

        file_put_contents(getenv("PHPCTL_RESULT_FILE"), json_encode([
            "ok" => $exitCode === 0,
            "exit_code" => $exitCode,
            "stdout" => (string) $stdout,
            "stderr" => (string) $stderr,
        ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
    '
}

phpctl_server_http_response() {
    status_line="$1"
    content_type="$2"
    body_file="$3"

    body_len="$(wc -c < "${body_file}" | tr -d '[:space:]')"
    printf 'HTTP/1.1 %s\r\n' "${status_line}"
    printf 'Content-Type: %s\r\n' "${content_type}"
    printf 'Content-Length: %s\r\n' "${body_len}"
    printf 'Connection: close\r\n'
    printf '\r\n'
    cat "${body_file}"
}

phpctl_serve_handle_connection() {
    req_file="$(mktemp_file)"
    response_body="$(mktemp_file)"
    meta_file="$(mktemp_file)"
    status_line="404 Not Found"
    content_type="application/json"

    cat > "${req_file}"
    http_read_request_meta "${req_file}" "${meta_file}"

    method="$(sed -n 's/^method=//p' "${meta_file}" | head -n1)"
    path="$(sed -n 's/^path=//p' "${meta_file}" | head -n1)"

    case "${method}:${path}" in
        GET:/healthz|GET:/readyz)
            if "${SELF_PATH}" --output json health > "${response_body}" 2>/dev/null; then
                status_line="200 OK"
            else
                printf '{"ok":false}\n' > "${response_body}"
                status_line="503 Service Unavailable"
            fi
            ;;
        GET:/status)
            "${SELF_PATH}" --output json status > "${response_body}"
            status_line="200 OK"
            ;;
        GET:/metrics)
            "${SELF_PATH}" --output text metrics > "${response_body}"
            status_line="200 OK"
            content_type="text/plain; version=0.0.4"
            ;;
        *)
            printf '{"ok":false,"error":"not found"}\n' > "${response_body}"
            status_line="404 Not Found"
            ;;
    esac

    phpctl_server_http_response "${status_line}" "${content_type}" "${response_body}"

    rm -f "${req_file}" "${response_body}" "${meta_file}"
}

phpctl_server_handle_connection() {
    req_file="$(mktemp_file)"
    body_file="$(mktemp_file)"
    response_body="$(mktemp_file)"
    result_file="$(mktemp_file)"
    meta_file="$(mktemp_file)"
    status_line="404 Not Found"
    content_type="application/json"

    cat > "${req_file}"
    http_read_request_meta "${req_file}" "${meta_file}"
    http_extract_body "${req_file}" "${body_file}"

    method="$(sed -n 's/^method=//p' "${meta_file}" | head -n1)"
    path="$(sed -n 's/^path=//p' "${meta_file}" | head -n1)"
    content_length="$(sed -n 's/^content_length=//p' "${meta_file}" | head -n1)"
    [ -n "${content_length}" ] || content_length="0"

    case "${method}:${path}" in
        GET:/healthz|GET:/readyz)
            if "${SELF_PATH}" --output json health > "${response_body}" 2>/dev/null; then
                status_line="200 OK"
            else
                printf '{"ok":false}\n' > "${response_body}"
                status_line="503 Service Unavailable"
            fi
            ;;
        GET:/status)
            "${SELF_PATH}" --output json status > "${response_body}"
            status_line="200 OK"
            ;;
        GET:/metrics)
            "${SELF_PATH}" --output text metrics > "${response_body}"
            status_line="200 OK"
            content_type="text/plain; version=0.0.4"
            ;;
        POST:/run)
            if [ "${content_length}" -gt 0 ] 2>/dev/null; then
                phpctl_server_run_payload "${body_file}" "${result_file}"
                cat "${result_file}" > "${response_body}"
                status_line="200 OK"
            else
                printf '{"ok":false,"exit_code":1,"stdout":"","stderr":"Empty request body"}\n' > "${response_body}"
                status_line="400 Bad Request"
            fi
            ;;
        *)
            printf '{"ok":false,"error":"not found"}\n' > "${response_body}"
            status_line="404 Not Found"
            ;;
    esac

    phpctl_server_http_response "${status_line}" "${content_type}" "${response_body}"

    rm -f "${req_file}" "${body_file}" "${response_body}" "${result_file}" "${meta_file}"
}

