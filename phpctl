ext_emit_install_skip() {
    ext="$1"
    type="$2"
    enable_after="$3"
    requested_package="$4"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"
    details="already-installed"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    elif ext_is_loaded "${ext}"; then
        avail="yes"
        details="already-loaded"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    if [ "${enable_after}" = "yes" ] && [ "${active}" != "yes" ]; then
        if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
            mkdir -p "${PHP_EXT_ACTIVE_DIR}"
            ini_path="$(resolve_ext_ini "${ext}")"
            ln -sf "${ini_path}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${ini_path}")"
            active="yes"
            active_ini="$(resolve_ext_active_ini "${ext}" 2>/dev/null || printf '%s' -)"
        elif ext_module_file_exists "${ext}"; then
            available_ini="$(ext_write_ini "${ext}" "${ext}" "")"
            mkdir -p "${PHP_EXT_ACTIVE_DIR}"
            ln -sf "${available_ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
            avail="yes"
            active="yes"
            active_ini="${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
        else
            details="already-loaded-no-ini"
        fi
    fi

    emit_object <<EOF
ok=yes
action=install
extension=${ext}
type=${type}
requested_package=${requested_package}
enabled=${enable_after}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
available_ini=${available_ini}
active_ini=${active_ini}
cleanup_performed=no
skipped=yes
details=${details}
EOF
}

ext_install() {
    [ $# -gt 0 ] || die "Usage: ${PROG} ext install <ext> [options]"

    ext="$1"
    shift

    type="auto"
    enable_after="no"
    pecl_version=""
    apk_deps=""
    runtime_pkgs=""
    jobs="1"
    ini_name=""
    force="no"
    no_cleanup="no"
    configure_args_file="$(mktemp_file)"
    : > "${configure_args_file}"

    while [ $# -gt 0 ]; do
        case "$1" in
            --type)
                shift
                [ $# -gt 0 ] || die "Missing value for --type"
                case "$1" in
                    auto|core|pecl) type="$1" ;;
                    *) rm -f "${configure_args_file}"; die "Unsupported extension type: $1" ;;
                esac
                shift
                ;;
            --enable)
                enable_after="yes"
                shift
                ;;
            --version)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --version"; }
                pecl_version="$1"
                shift
                ;;
            --apk)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    apk_deps="${apk_deps} $1"
                    shift
                done
                ;;
            --runtime)
                shift
                while [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; do
                    runtime_pkgs="${runtime_pkgs} $1"
                    shift
                done
                ;;
            --jobs)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --jobs"; }
                jobs="$1"
                shift
                ;;
            --configure)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --configure"; }
                printf '%s\n' "$1" >> "${configure_args_file}"
                shift
                ;;
            --ini-name)
                shift
                [ $# -gt 0 ] || { rm -f "${configure_args_file}"; die "Missing value for --ini-name"; }
                ini_name="$1"
                shift
                ;;
            --force)
                force="yes"
                shift
                ;;
            --no-cleanup)
                no_cleanup="yes"
                shift
                ;;
            -h|--help)
                rm -f "${configure_args_file}"
                ext_install_usage
                return 0
                ;;
            *)
                rm -f "${configure_args_file}"
                die "Unknown install option: $1"
                ;;
        esac
    done

    requested_package="${ext}"
    if [ -n "${pecl_version}" ]; then
        requested_package="${ext}-${pecl_version}"
    fi

    detected_for_auto=""
    if [ "${type}" = "auto" ]; then
        detected_for_auto="$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)"
        case "${detected_for_auto}" in
            core)
                type="core"
                ;;
            pecl)
                type="pecl"
                ;;
            core-known-but-source-not-extracted)
                type="core"
                ;;
            core-known-but-source-missing)
                rm -f "${configure_args_file}"
                die "Extension looks like a core extension but PHP source helper or source tarball is missing: ${ext}"
                ;;
            *)
                rm -f "${configure_args_file}"
                die "Unable to detect extension type for: ${ext}"
                ;;
        esac
    fi

    if [ "${type}" = "core" ] && [ -n "${pecl_version}" ]; then
        rm -f "${configure_args_file}"
        die "--version is only supported for PECL extensions"
    fi

    if [ "${force}" != "yes" ] && ext_already_present "${ext}"; then
        rm -f "${configure_args_file}"
        ext_emit_install_skip "${ext}" "${type}" "${enable_after}" "${requested_package}"
        return 0
    fi

    if [ "${force}" = "yes" ]; then
        ext_disable "${ext}" >/dev/null 2>&1 || true

        if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
            rm -f "$(resolve_ext_ini "${ext}")"
        fi

        if [ -f "$(php_extension_dir)/${ext}.so" ]; then
            rm -f "$(php_extension_dir)/${ext}.so"
        fi

        if [ "${type}" = "pecl" ] && cmd_exists "${PECL_BIN}"; then
            "${PECL_BIN}" uninstall -r "${ext}" >/dev/null 2>&1 || true
        fi
    fi

    if [ "${type}" = "pecl" ]; then
        ext_install_pecl "${ext}" "${pecl_version}" "${enable_after}" "${no_cleanup}" "${ini_name}" "${apk_deps# }" "${runtime_pkgs# }"
        package="${requested_package}"
    else
        ext_install_core "${ext}" "${jobs}" "${enable_after}" "${no_cleanup}" "${ini_name}" "${apk_deps# }" "${runtime_pkgs# }" "${configure_args_file}"
        package="${ext}"
    fi

    rm -f "${configure_args_file}"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    emit_object <<EOF
ok=yes
action=install
extension=${ext}
type=${type}
requested_package=${package}
enabled=${enable_after}
available=${avail}
active=${active}
loaded=${loaded}
version=${version}
available_ini=${available_ini}
active_ini=${active_ini}
cleanup_performed=$( [ "${no_cleanup}" = "yes" ] && printf '%s' "no" || printf '%s' "yes" )
EOF
}

ext_uninstall_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ext uninstall <ext> [--type auto|core|pecl] [--force]
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ext_uninstall
usage=${PROG} ext uninstall <ext> [--type auto|core|pecl] [--force]
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ext_uninstall() {
    [ $# -gt 0 ] || die "Usage: ${PROG} ext uninstall <ext> [options]"
    ext="$1"
    shift

    type="auto"
    force="no"

    while [ $# -gt 0 ]; do
        case "$1" in
            --type)
                shift
                [ $# -gt 0 ] || die "Missing value for --type"
                type="$1"
                shift
                ;;
            --force)
                force="yes"
                shift
                ;;
            -h|--help)
                ext_uninstall_usage
                return 0
                ;;
            *)
                die "Unknown uninstall option: $1"
                ;;
        esac
    done

    if [ "${type}" = "auto" ]; then
        detected="$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)"
        case "${detected}" in
            core|core-known-but-source-not-extracted|core-known-but-source-missing) type="core" ;;
            pecl) type="pecl" ;;
            *) type="unknown" ;;
        esac
    fi

    if [ "${force}" != "yes" ] && resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        die "Extension is active: ${ext}. Disable it first or use --force."
    fi

    ext_disable "${ext}" >/dev/null 2>&1 || true

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        rm -f "$(resolve_ext_ini "${ext}")"
    fi

    if [ -f "$(php_extension_dir)/${ext}.so" ]; then
        rm -f "$(php_extension_dir)/${ext}.so"
    fi

    if [ "${type}" = "pecl" ] && cmd_exists "${PECL_BIN}"; then
        "${PECL_BIN}" uninstall -r "${ext}" >/dev/null 2>&1 || true
    fi

    emit_object <<EOF
ok=yes
action=uninstall
extension=${ext}
type=${type}
removed=yes
EOF
}

handle_ext() {
    [ $# -gt 0 ] || { ext_usage; return 0; }

    case "$1" in
        help|--help|-h)
            ext_usage
            ;;
        list)
            shift
            ext_list "$@"
            ;;
        list-loaded)
            shift
            ext_list_loaded "$@"
            ;;
        versions)
            shift
            ext_versions "$@"
            ;;
        detect)
            shift
            ext_detect "$@"
            ;;
        pecl-list)
            shift
            ext_pecl_list "$@"
            ;;
        so-list)
            shift
            ext_so_list "$@"
            ;;
        status)
            shift
            ext_status "$@"
            ;;
        install)
            shift
            ext_install "$@"
            ;;
        uninstall)
            shift
            ext_uninstall "$@"
            ;;
        enable)
            shift
            ext_enable "$@"
            ;;
        disable)
            shift
            ext_disable "$@"
            ;;
        enable-all)
            shift
            ext_enable_all "$@"
            ;;
        disable-all)
            shift
            ext_disable_all "$@"
            ;;
        doctor)
            shift
            ext_doctor "$@"
            ;;
        *)
            die "Unknown ext subcommand: $1"
            ;;
    esac
}

case "${1:-}" in
    __serve_stdio)
        shift
        phpctl_serve_handle_connection
        exit 0
        ;;
    __server_stdio)
        shift
        phpctl_server_handle_connection
        exit 0
        ;;
esac

while [ $# -gt 0 ]; do
    case "$1" in
        --output)
            shift
            [ $# -gt 0 ] || die "Missing value for --output"
            case "$1" in
                text|json|tsv)
                    OUTPUT_FORMAT="$1"
                    ;;
                *)
                    die "Unsupported output format: $1"
                    ;;
            esac
            shift
            ;;
        --client)
            PHPCTL_REMOTE_MODE="client"
            shift
            ;;
        --server)
            PHPCTL_REMOTE_MODE="server"
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [ "${PHPCTL_REMOTE_MODE}" = "client" ]; then
    phpctl_client_run "$@"
    exit $?
fi

if [ "${PHPCTL_REMOTE_MODE}" = "server" ]; then
    phpctl_server_run "$@"
    exit $?
fi

