fpm_status() {
    bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    available="no"
    config_ok="no"

    if cmd_exists "${PHP_FPM_BIN}"; then
        available="yes"
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            config_ok="yes"
        fi
    fi

    emit_object <<EOF
php_fpm_bin=${bin_path}
available=${available}
config_ok=${config_ok}
master_pid=$(php_fpm_master_pid 2>/dev/null || printf '%s' -)
EOF
}

fpm_test() {
    if ! cmd_exists "${PHP_FPM_BIN}"; then
        die "php-fpm binary not found"
    fi

    if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
        status="ok"
        ok="yes"
        details="configuration valid"
    else
        status="fail"
        ok="no"
        details="configuration invalid"
    fi

    emit_object <<EOF
ok=${ok}
status=${status}
details=${details}
EOF
}

fpm_reload() {
    cmd_exists "${PHP_FPM_BIN}" || die "php-fpm binary not found"
    "${PHP_FPM_BIN}" -t >/dev/null 2>&1 || die "php-fpm configuration invalid"

    pid="$(php_fpm_master_pid 2>/dev/null || true)"
    [ -n "${pid}" ] || die "php-fpm master process not found"

    kill -s "${PHP_FPM_RELOAD_SIGNAL}" "${pid}" >/dev/null 2>&1 || die "Unable to send reload signal"

    emit_object <<EOF
ok=yes
status=ok
signal=${PHP_FPM_RELOAD_SIGNAL}
pid=${pid}
details=reloaded
EOF
}

fpm_pool_list() {
    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_AVAILABLE_DIR}"/*; do
            [ -e "${f}" ] || continue
            pool_name_from_path "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_ACTIVE_DIR}"/*; do
            [ -e "${f}" ] || continue
            case "$(basename "${f}")" in
                *.conf|*.pool.conf) pool_name_from_path "${f}" >> "${tmp_names}" ;;
            esac
        done
    fi

    printf 'name\tavailable\tactive\tavailable_path\tactive_path\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r name; do
            [ -n "${name}" ] || continue
            avail="no"
            active="no"
            available_path="-"
            active_path="-"

            if resolve_pool_available "${name}" >/dev/null 2>&1; then
                avail="yes"
                available_path="$(resolve_pool_available "${name}")"
            fi

            if resolve_pool_active "${name}" >/dev/null 2>&1; then
                active="yes"
                active_path="$(resolve_pool_active "${name}")"
            fi

            printf '%s\t%s\t%s\t%s\t%s\n' "${name}" "${avail}" "${active}" "${available_path}" "${active_path}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"

    rm -f "${tmp_names}" "${tmp_rows}"
}

fpm_pool_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool enable <name>"
    name="$1"
    src="$(resolve_pool_available "${name}" 2>/dev/null || true)"
    [ -n "${src}" ] || die "Pool not found in available dir: ${name}"

    mkdir -p "${PHP_FPM_POOL_ACTIVE_DIR}"
    ln -sf "${src}" "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")"

    emit_object <<EOF
ok=yes
action=enable
pool=${name}
active=yes
active_path=${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")
EOF
}

fpm_pool_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool disable <name>"
    name="$1"
    dst="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    [ -n "${dst}" ] || die "Pool not active: ${name}"

    rm -f "${dst}"

    emit_object <<EOF
ok=yes
action=disable
pool=${name}
active=no
removed_path=${dst}
EOF
}

fpm_pool_delete() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool delete <name>"
    name="$1"

    active_path="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    available_path="$(resolve_pool_available "${name}" 2>/dev/null || true)"

    [ -n "${active_path}" ] && rm -f "${active_path}"
    [ -n "${available_path}" ] && rm -f "${available_path}"

    emit_object <<EOF
ok=yes
action=delete
pool=${name}
removed=yes
EOF
}

fpm_pool_validate() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool validate <name>"
    name="$1"
    resolve_pool_available "${name}" >/dev/null 2>&1 || die "Pool not found in available dir: ${name}"
    fpm_test
}

fpm_pool_show() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool show <name>"
    name="$1"

    avail="no"
    active="no"
    available_path="-"
    active_path="-"

    if resolve_pool_available "${name}" >/dev/null 2>&1; then
        avail="yes"
        available_path="$(resolve_pool_available "${name}")"
    fi

    if resolve_pool_active "${name}" >/dev/null 2>&1; then
        active="yes"
        active_path="$(resolve_pool_active "${name}")"
    fi

    emit_object <<EOF
pool=${name}
available=${avail}
active=${active}
available_path=${available_path}
active_path=${active_path}
EOF
}

handle_fpm() {
    [ $# -gt 0 ] || { fpm_usage; return 0; }

    case "$1" in
        help|--help|-h)
            fpm_usage
            ;;
        status)
            shift
            fpm_status "$@"
            ;;
        test)
            shift
            fpm_test "$@"
            ;;
        configtest)
            shift
            fpm_test "$@"
            ;;
        reload)
            shift
            fpm_reload "$@"
            ;;
        pool)
            shift
            [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool <list|render|create|generate|import|enable|disable|delete|validate|show> ..."
            case "$1" in
                help|--help|-h)
                    fpm_usage
                    ;;
                list)
                    shift
                    fpm_pool_list "$@"
                    ;;
                render)
                    shift
                    fpm_pool_render "$@"
                    ;;
                create)
                    shift
                    fpm_pool_create "$@"
                    ;;
                generate)
                    shift
                    fpm_pool_generate "$@"
                    ;;
                import)
                    shift
                    fpm_pool_import "$@"
                    ;;
                enable)
                    shift
                    fpm_pool_enable "$@"
                    ;;
                disable)
                    shift
                    fpm_pool_disable "$@"
                    ;;
                delete)
                    shift
                    fpm_pool_delete "$@"
                    ;;
                validate)
                    shift
                    fpm_pool_validate "$@"
                    ;;
                show)
                    shift
                    fpm_pool_show "$@"
                    ;;
                *)
                    die "Unknown fpm pool subcommand: $1"
                    ;;
            esac
            ;;
        *)
            die "Unknown fpm subcommand: $1"
            ;;
    esac
}

ini_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} ini <subcommand> [args]

Subcommands:
  show                 Show php ini information
  get <key>            Read a single ini value
  scan                 Show additional ini scan directory
  loaded               Show loaded php.ini path
  help                 Show this help

Examples:
  ${PROG} ini show
  ${PROG} ini get memory_limit
  ${PROG} ini get opcache.enable
  ${PROG} ini scan
  ${PROG} ini loaded
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=ini
usage=${PROG} ini <subcommand> [args]
subcommands=show,get,scan,loaded,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

ini_show() {
    if [ "${OUTPUT_FORMAT}" = "text" ]; then
        "${PHP_BIN}" --ini
        return 0
    fi

    loaded_ini="$(php_loaded_ini)"
    scan_dir="$(php_ini_scan_dir)"
    parsed_files="$(php_parsed_ini_files | paste -sd ',' -)"
    parsed_count="$(php_parsed_ini_files | awk 'NF { c++ } END { print c+0 }')"

    emit_object <<EOF
loaded_ini=${loaded_ini}
scan_dir=${scan_dir}
parsed_files_count=${parsed_count}
parsed_files=${parsed_files}
EOF
}

ini_get() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ini get <key>"
    key="$1"
    value="$("${PHP_BIN}" -r 'echo ini_get($argv[1]), PHP_EOL;' "${key}" 2>/dev/null || true)"

    emit_object <<EOF
key=${key}
value=${value}
EOF
}

ini_scan() {
    emit_object <<EOF
scan_dir=$(php_ini_scan_dir)
EOF
}

ini_loaded() {
    emit_object <<EOF
loaded_ini=$(php_loaded_ini)
EOF
}

handle_ini() {
    [ $# -gt 0 ] || { ini_usage; return 0; }

    case "$1" in
        help|--help|-h)
