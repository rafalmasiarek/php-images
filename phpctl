set -eu

PROG="${0##*/}"
VERSION="0.3.3"

OUTPUT_FORMAT="${PHPCTL_OUTPUT_FORMAT:-text}"

PHP_BIN="${PHPCTL_PHP_BIN:-${PHP_BIN:-php}}"
PHP_FPM_BIN="${PHPCTL_PHP_FPM_BIN:-${PHP_FPM_BIN:-php-fpm}}"
PECL_BIN="${PHPCTL_PECL_BIN:-${PECL_BIN:-pecl}}"
PHPIZE_BIN="${PHPCTL_PHPIZE_BIN:-${PHPIZE_BIN:-phpize}}"
MAKE_BIN="${PHPCTL_MAKE_BIN:-${MAKE_BIN:-make}}"
READ_ELF_BIN="${PHPCTL_READ_ELF_BIN:-${READ_ELF_BIN:-readelf}}"
NC_BIN="${PHPCTL_NC_BIN:-${NC_BIN:-nc}}"

PHP_INI_DIR="${PHPCTL_PHP_INI_DIR:-${PHP_INI_DIR:-/usr/local/etc/php}}"
PHP_EXT_AVAILABLE_DIR="${PHPCTL_PHP_EXT_AVAILABLE_DIR:-${PHP_EXT_AVAILABLE_DIR:-${PHP_INI_DIR}/conf.d/available}}"
PHP_EXT_ACTIVE_DIR="${PHPCTL_PHP_EXT_ACTIVE_DIR:-${PHP_EXT_ACTIVE_DIR:-${PHP_INI_DIR}/conf.d}}"

PHP_FPM_CONF_DIR="${PHPCTL_PHP_FPM_CONF_DIR:-${PHP_FPM_CONF_DIR:-/usr/local/etc}}"
PHP_FPM_POOL_AVAILABLE_DIR="${PHPCTL_PHP_FPM_POOL_AVAILABLE_DIR:-${PHP_FPM_POOL_AVAILABLE_DIR:-${PHP_FPM_CONF_DIR}/php-fpm.d/available}}"
PHP_FPM_POOL_ACTIVE_DIR="${PHPCTL_PHP_FPM_POOL_ACTIVE_DIR:-${PHP_FPM_POOL_ACTIVE_DIR:-${PHP_FPM_CONF_DIR}/php-fpm.d}}"
PHP_FPM_POOL_TEMPLATE="${PHPCTL_PHP_FPM_POOL_TEMPLATE:-${PHP_FPM_POOL_TEMPLATE:-}}"
PHP_FPM_RELOAD_SIGNAL="${PHPCTL_PHP_FPM_RELOAD_SIGNAL:-${PHP_FPM_RELOAD_SIGNAL:-HUP}}"

PHP_SRC_DIR="${PHPCTL_PHP_SRC_DIR:-${PHP_SRC_DIR:-/usr/src/php}}"
PHP_BUILD_DEPS_VIRTUAL="${PHPCTL_PHP_BUILD_DEPS_VIRTUAL:-.phpctl-php-ext-build}"
PHP_BUILD_DEPS="${PHPCTL_PHP_BUILD_DEPS:-${PHP_BUILD_DEPS:-${PHPIZE_DEPS:-autoconf dpkg-dev dpkg file g++ gcc libc-dev make pkgconf re2c} linux-headers pkgconfig re2c git binutils}}"

PHPCTL_SERVE_LISTEN="${PHPCTL_SERVE_LISTEN:-0.0.0.0:8080}"
PHPCTL_SERVER_LISTEN="${PHPCTL_SERVER_LISTEN:-${PHPCTL_SERVE_LISTEN}}"
PHPCTL_CLIENT_CONF="${PHPCTL_CLIENT_CONF:-${HOME:-/root}/.phpctl/client.conf}"

PHPCTL_REMOTE_MODE=""
PHPCTL_REMOTE_HOST=""
PHPCTL_REMOTE_CREDENTIALS=""

cmd_exists() {
    command -v "$1" >/dev/null 2>&1
}

mktemp_file() {
    mktemp "${TMPDIR:-/tmp}/phpctl.XXXXXX"
}

json_quote() {
    "${PHP_BIN}" -r 'echo json_encode($argv[1], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);' "$1"
}

die() {
    msg="$*"
    case "${OUTPUT_FORMAT}" in
        text)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
        json)
            printf '{"ok":false,"error":%s}\n' "$(json_quote "${msg}")" >&2
            ;;
        tsv)
            printf 'ok\terror\nno\t%s\n' "${msg}" >&2
            ;;
        *)
            printf 'ERROR: %s\n' "${msg}" >&2
            ;;
    esac
    exit 1
}

php_ini_scan_dir() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Scan for additional .ini files in: ||p' | head -n1
}

php_loaded_ini() {
    "${PHP_BIN}" --ini 2>/dev/null | sed -n 's|^Loaded Configuration File: *||p' | head -n1
}

php_extension_dir() {
    "${PHP_BIN}" -r 'echo ini_get("extension_dir"), PHP_EOL;' 2>/dev/null || true
}

php_loaded_extensions_list() {
    "${PHP_BIN}" -r '
        $a = get_loaded_extensions();
        $b = function_exists("get_loaded_extensions") ? get_loaded_extensions(true) : [];
        $exts = array_values(array_unique(array_merge($a, $b)));
        sort($exts, SORT_NATURAL | SORT_FLAG_CASE);
        foreach ($exts as $e) {
            echo $e, PHP_EOL;
        }
    ' 2>/dev/null || true
}

php_ext_version() {
    ext="$1"
    if ext_is_loaded "${ext}"; then
        "${PHP_BIN}" -r '
            $v = phpversion($argv[1]);
            if ($v === false || $v === null || $v === "") {
                $v = "(built-in/unknown)";
            }
            echo $v, PHP_EOL;
        ' "${ext}" 2>/dev/null || printf '%s\n' "-"
    else
        printf '%s\n' "-"
    fi
}

php_parsed_ini_files() {
    "${PHP_BIN}" --ini 2>/dev/null | awk '
        BEGIN { capture=0 }
        /^Additional .ini files parsed:/ { capture=1; next }
        capture == 1 {
            line=$0
            sub(/^[[:space:]]+/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line == "(none)") next
            if (line != "") print line
        }
    ' || true
}

emit_object() {
    tmp="$(mktemp_file)"
    cat > "${tmp}"

    case "${OUTPUT_FORMAT}" in
        text)
            while IFS='=' read -r k v; do
                [ -n "${k}" ] || continue
                printf '%-20s %s\n' "${k}:" "${v}"
            done < "${tmp}"
            ;;
        json)
            TMP_OBJECT_FILE="${tmp}" "${PHP_BIN}" -r '
                $file = getenv("TMP_OBJECT_FILE");
                $out = [];
                foreach (file($file, FILE_IGNORE_NEW_LINES) as $line) {
                    if ($line === "") {
                        continue;
                    }
                    $parts = explode("=", $line, 2);
                    $key = $parts[0];
                    $value = isset($parts[1]) ? $parts[1] : "";
                    if ($value === "yes") {
                        $out[$key] = true;
                    } elseif ($value === "no") {
                        $out[$key] = false;
                    } else {
                        $out[$key] = $value;
                    }
                }
                echo json_encode($out, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
            '
            ;;
        tsv)
            awk -F '=' '
                BEGIN { first=1 }
                {
                    if (!first) printf "\t";
                    printf "%s", $1;
                    first=0;
                    vals[NR]=substr($0, length($1) + 2);
                    n=NR;
                }
                END {
                    printf "\n";
                    for (i=1; i<=n; i++) {
                        if (i>1) printf "\t";
                        printf "%s", vals[i];
                    }
                    printf "\n";
                }
            ' "${tmp}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${tmp}"
}

pretty_print_tsv() {
    file="$1"
    awk -F '\t' '
        {
            rows[NR]=$0
            for (i=1; i<=NF; i++) {
                if (length($i) > w[i]) {
                    w[i] = length($i)
                }
            }
            if (NF > nf) {
                nf = NF
            }
            nr = NR
        }
        END {
            for (r=1; r<=nr; r++) {
                split(rows[r], f, FS)
                for (i=1; i<=nf; i++) {
                    val = f[i]
                    if (i < nf) {
                        printf "%-*s", w[i] + 2, val
                    } else {
                        printf "%s", val
                    }
                }
                printf "\n"
            }
        }
    ' "${file}"
}

tsv_file_to_json() {
    file="$1"
    TSV_JSON_FILE="${file}" "${PHP_BIN}" -r '
        $file = getenv("TSV_JSON_FILE");
        $lines = file($file, FILE_IGNORE_NEW_LINES);
        if (!$lines || count($lines) === 0) {
            echo "[]\n";
            exit(0);
        }
        $header = explode("\t", array_shift($lines));
        $rows = [];
        foreach ($lines as $line) {
            if ($line === "") {
                continue;
            }
            $cols = explode("\t", $line);
            $row = [];
            foreach ($header as $i => $key) {
                $value = array_key_exists($i, $cols) ? $cols[$i] : "";
                if ($value === "yes") {
                    $row[$key] = true;
                } elseif ($value === "no") {
                    $row[$key] = false;
                } else {
                    $row[$key] = $value;
                }
            }
            $rows[] = $row;
        }
        echo json_encode($rows, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
    '
}

render_table_file() {
    file="$1"
    case "${OUTPUT_FORMAT}" in
        text)
            pretty_print_tsv "${file}"
            ;;
        json)
            tsv_file_to_json "${file}"
            ;;
        tsv)
            cat "${file}"
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

apk_add_if_any() {
    if [ $# -gt 0 ] && [ -n "$*" ]; then
        apk add --no-cache "$@"
    fi
}

php_build_deps_install() {
    if apk info --installed "${PHP_BUILD_DEPS_VIRTUAL}" >/dev/null 2>&1; then
        return 0
    fi
    apk add --no-cache --virtual "${PHP_BUILD_DEPS_VIRTUAL}" ${PHP_BUILD_DEPS}
}

php_build_deps_cleanup() {
    apk del "${PHP_BUILD_DEPS_VIRTUAL}" >/dev/null 2>&1 || true
}

php_fpm_master_pid() {
    if cmd_exists pidof; then
        pidof "$(basename "${PHP_FPM_BIN}")" 2>/dev/null | awk '{print $1}' | head -n1
        return 0
    fi
    ps 2>/dev/null | awk '/php-fpm: master process/ { print $1; exit }'
}

resolve_ext_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_AVAILABLE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/${ext}.ini" \
        "${PHP_EXT_AVAILABLE_DIR}/zz-${ext}.ini"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

resolve_ext_active_ini() {
    ext="$1"

    for candidate in \
        "${PHP_EXT_ACTIVE_DIR}/docker-php-ext-${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/${ext}.ini" \
        "${PHP_EXT_ACTIVE_DIR}/zz-${ext}.ini"
    do
        [ -e "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done

    return 1
}

ext_name_from_ini() {
    base="$(basename "$1")"
    name="${base#docker-php-ext-}"
    name="${name#zz-}"
    name="${name%.ini}"
    printf '%s\n' "${name}"
}

ext_is_loaded() {
    ext="$1"
    php_loaded_extensions_list | grep -Fxi "${ext}" >/dev/null 2>&1
}

ext_module_file_exists() {
    ext="$1"
    extdir="$(php_extension_dir)"
    [ -n "${extdir}" ] && [ -f "${extdir}/${ext}.so" ]
}

ext_is_available() {
    ext="$1"
    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        return 0
    fi
    if ext_module_file_exists "${ext}"; then
        return 0
    fi
    return 1
}

ext_core_dir() {
    printf '%s\n' "${PHP_SRC_DIR}/ext/$1"
}

ext_is_known_core() {
    case "$1" in
        bcmath|bz2|calendar|ctype|curl|dba|dom|enchant|exif|ffi|fileinfo|ftp|gd|gettext|gmp|iconv|imap|intl|ldap|mbstring|mysqli|opcache|pcntl|pdo|pdo_mysql|pdo_pgsql|pdo_sqlite|pgsql|phar|posix|shmop|simplexml|snmp|soap|sockets|sodium|sysvmsg|sysvsem|sysvshm|tidy|tokenizer|xml|xmlreader|xmlwriter|xsl|zip)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

ext_detect_type_value() {
    ext="$1"
    if ext_is_known_core "${ext}"; then
        printf '%s\n' "core"
        return 0
    fi
    if cmd_exists "${PECL_BIN}" && "${PECL_BIN}" remote-info "${ext}" >/dev/null 2>&1; then
        printf '%s\n' "pecl"
        return 0
    fi
    printf '%s\n' "unknown"
    return 1
}

collect_ext_row() {
    ext="$1"

    avail="no"
    active="no"
    loaded="no"
    version="-"
    available_ini="-"
    active_ini="-"

    if resolve_ext_ini "${ext}" >/dev/null 2>&1; then
        avail="yes"
        available_ini="$(resolve_ext_ini "${ext}")"
    elif ext_module_file_exists "${ext}"; then
        avail="yes"
    fi

    if resolve_ext_active_ini "${ext}" >/dev/null 2>&1; then
        active="yes"
        active_ini="$(resolve_ext_active_ini "${ext}")"
    fi

    if ext_is_loaded "${ext}"; then
        loaded="yes"
        version="$(php_ext_version "${ext}")"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${ext}" "${avail}" "${active}" "${loaded}" "${version}" "$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)" "${available_ini}" "${active_ini}"
}

ext_ini_basename() {
    ext="$1"
    ini_name="$2"
    if [ -n "${ini_name}" ]; then
        case "${ini_name}" in
            *.ini) printf '%s\n' "${ini_name}" ;;
            *) printf '%s.ini\n' "${ini_name}" ;;
        esac
    else
        printf 'docker-php-ext-%s.ini\n' "${ext}"
    fi
}

ext_is_zend_extension() {
    module_path="$1"
    if cmd_exists "${READ_ELF_BIN}"; then
        "${READ_ELF_BIN}" --wide --syms "${module_path}" 2>/dev/null | grep -q ' zend_extension_entry$'
        return $?
    fi
    return 1
}

ext_write_ini() {
    ext="$1"
    module_name="$2"
    ini_name="$3"
    mkdir -p "${PHP_EXT_AVAILABLE_DIR}"
    ini_path="${PHP_EXT_AVAILABLE_DIR}/$(ext_ini_basename "${ext}" "${ini_name}")"
    if ext_is_zend_extension "$(php_extension_dir)/${module_name}.so"; then
        line="zend_extension=${module_name}"
    else
        line="extension=${module_name}"
    fi
    printf '%s\n' "${line}" > "${ini_path}"
    printf '%s\n' "${ini_path}"
}

# Prepare PHP source tree in the same way as the official helper.
php_source_prepare() {
    src_exists=""
    if [ -d "${PHP_SRC_DIR}" ]; then
        src_exists="1"
    fi

    cmd_exists docker-php-source || die "docker-php-source command not found"
    docker-php-source extract

    if [ -z "${src_exists}" ]; then
        touch "${PHP_SRC_DIR}/.docker-delete-me"
    fi
}

# Clean PHP source tree only if phpctl extracted it for this run.
php_source_cleanup() {
    if [ -e "${PHP_SRC_DIR}/.docker-delete-me" ]; then
        cmd_exists docker-php-source || die "docker-php-source command not found"
        docker-php-source delete
    fi
}

ext_detect() {
    [ $# -eq 1 ] || die "Usage: ${PROG} ext detect <ext>"
    ext="$1"
    detected="$(ext_detect_type_value "${ext}" 2>/dev/null || printf '%s' unknown)"
    buildable="no"
    installable="no"
    case "${detected}" in
        core|pecl)
            installable="yes"
            ;;
    esac
    [ "${detected}" = "core" ] && buildable="yes"
    emit_object <<EOF
name=${ext}
type=${detected}
buildable=${buildable}
installable=${installable}
core_dir=$(ext_core_dir "${ext}")
EOF
}

# Build and install a core extension from PHP sources.
ext_install_core() {
    ext="$1"
    jobs="$2"
    enable_after="$3"
    no_cleanup="$4"
    ini_name="$5"
    apk_deps="$6"
    runtime_pkgs="$7"
    configure_args_file="$8"

    cleanup_core_install() {
        php_source_cleanup
    }

    if [ -n "${runtime_pkgs}" ]; then
        apk_add_if_any ${runtime_pkgs}
    fi

    php_build_deps_install

    if [ -n "${apk_deps}" ]; then
        apk_add_if_any ${apk_deps}
    fi

    php_source_prepare
    trap cleanup_core_install EXIT INT TERM

    core_dir="$(ext_core_dir "${ext}")"
    [ -d "${core_dir}" ] || die "Core extension source directory not found: ${core_dir}"

    oldpwd="$(pwd)"
    cd "${core_dir}"

    : "${CFLAGS:=${PHP_CFLAGS:-}}"
    : "${CPPFLAGS:=${PHP_CPPFLAGS:-}}"
    : "${LDFLAGS:=${PHP_LDFLAGS:-}}"
    export CFLAGS CPPFLAGS LDFLAGS

    if [ ! -f configure ]; then
        "${PHPIZE_BIN}"
    fi

    if [ -s "${configure_args_file}" ]; then
        set --
        while IFS= read -r arg; do
            [ -n "${arg}" ] || continue
            set -- "$@" "${arg}"
        done < "${configure_args_file}"
        ./configure --enable-option-checking=fatal "$@"
    else
        ./configure --enable-option-checking=fatal
    fi

    "${MAKE_BIN}" -j"${jobs}"

    if ! "${PHP_BIN}" -n -d 'display_errors=stderr' -r 'exit(ZEND_DEBUG_BUILD ? 0 : 1);' >/dev/null 2>&1; then
        find modules \
            -maxdepth 1 \
            -name '*.so' \
            -exec sh -euxc 'strip --strip-all "$@" || :' -- '{}' +
    fi

    "${MAKE_BIN}" install
    "${MAKE_BIN}" clean >/dev/null 2>&1 || true

    cd "${oldpwd}"

    [ -f "$(php_extension_dir)/${ext}.so" ] || die "Installed module file not found for: ${ext}"

    available_ini="$(ext_write_ini "${ext}" "${ext}" "${ini_name}")"

    if [ "${enable_after}" = "yes" ]; then
        mkdir -p "${PHP_EXT_ACTIVE_DIR}"
        ln -sf "${available_ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
    fi

    trap - EXIT INT TERM
    php_source_cleanup

    if [ "${no_cleanup}" != "yes" ]; then
        php_build_deps_cleanup
    fi
}

# Install an extension from PECL.
ext_install_pecl() {
    ext="$1"
    version="$2"
    enable_after="$3"
    no_cleanup="$4"
    ini_name="$5"
    apk_deps="$6"
    runtime_pkgs="$7"

    cmd_exists "${PECL_BIN}" || die "pecl binary not found"

    if [ -n "${runtime_pkgs}" ]; then
        apk_add_if_any ${runtime_pkgs}
    fi

    php_build_deps_install

    if [ -n "${apk_deps}" ]; then
        apk_add_if_any ${apk_deps}
    fi

    package="${ext}"
    if [ -n "${version}" ]; then
        package="${ext}-${version}"
    fi

    "${PECL_BIN}" channel-update pecl.php.net >/dev/null 2>&1 || true
    yes '' | "${PECL_BIN}" install "${package}" >/dev/null

    [ -f "$(php_extension_dir)/${ext}.so" ] || die "Installed module file not found for: ${ext}"

    available_ini="$(ext_write_ini "${ext}" "${ext}" "${ini_name}")"

    if [ "${enable_after}" = "yes" ]; then
        mkdir -p "${PHP_EXT_ACTIVE_DIR}"
        ln -sf "${available_ini}" "${PHP_EXT_ACTIVE_DIR}/$(basename "${available_ini}")"
    fi

    if [ "${no_cleanup}" != "yes" ]; then
        php_build_deps_cleanup
    fi
}

usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
${PROG} - PHP image control utility

Usage:
  ${PROG} [--output text|json|tsv] <command> [subcommand] [options]
  ${PROG} --client [--host <socket|host:port>] [--credentials <user:password>] <command> ...
  ${PROG} --server [--listen <socket|host:port>]

Commands:
  help                 Show this help
  version              Show ${PROG} version
  info                 Show PHP runtime information
  paths                Show important filesystem paths
  doctor               Run diagnostics
  self-test            Run quick runtime checks
  status               Show runtime status
  health               Show runtime health
  metrics              Show metrics
  serve                Serve health, status and metrics
  server               Serve HTTP API for remote control
  client               Call remote phpctl API
  ext                  Manage PHP extensions
  fpm                  Manage PHP-FPM pools and config
  ini                  Inspect PHP ini/config values

Examples:
  ${PROG} version
  ${PROG} info
  ${PROG} ext list
  ${PROG} ext install redis --enable
  ${PROG} fpm pool list
  ${PROG} fpm pool bundle import --json-file /tmp/pools.json --reload
  ${PROG} --server --listen 0.0.0.0:8080
  ${PROG} --client --host 127.0.0.1:8080 info

Run:
  ${PROG} <command> --help
EOF
            ;;
        json|tsv)
            emit_object <<EOF
name=${PROG}
version=${VERSION}
usage=${PROG} [--output text|json|tsv] <command> [subcommand] [options]
commands=help,version,info,paths,doctor,self-test,status,health,metrics,serve,server,client,ext,fpm,ini
default_output=${OUTPUT_FORMAT}
output_formats=text,json,tsv
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

show_version() {
    case "${OUTPUT_FORMAT}" in
        text)
            printf '%s v%s\n' "${PROG}" "${VERSION}"
            ;;
        json|tsv)
            emit_object <<EOF
name=${PROG}
version=${VERSION}
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

show_info() {
    php_bin_path="$(command -v "${PHP_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    php_version="$("${PHP_BIN}" -r 'echo PHP_VERSION;' 2>/dev/null || printf '%s\n' "unknown")"
    php_sapi="$("${PHP_BIN}" -r 'echo PHP_SAPI;' 2>/dev/null || printf '%s\n' "unknown")"
    loaded_ini="$(php_loaded_ini)"
    ini_scan_dir="$(php_ini_scan_dir)"
    extension_dir="$(php_extension_dir)"
    php_fpm_bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"

    emit_object <<EOF
php_bin=${php_bin_path}
php_version=${php_version}
php_sapi=${php_sapi}
loaded_ini=${loaded_ini}
ini_scan_dir=${ini_scan_dir}
extension_dir=${extension_dir}
php_fpm_bin=${php_fpm_bin_path}
EOF
}

show_paths() {
    php_bin_path="$(command -v "${PHP_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    php_fpm_bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    loaded_ini="$(php_loaded_ini)"
    ini_scan_dir="$(php_ini_scan_dir)"
    extension_dir="$(php_extension_dir)"

    emit_object <<EOF
php_bin=${php_bin_path}
php_fpm_bin=${php_fpm_bin_path}
loaded_ini=${loaded_ini}
ini_scan_dir=${ini_scan_dir}
extension_dir=${extension_dir}
ext_available_dir=${PHP_EXT_AVAILABLE_DIR}
ext_active_dir=${PHP_EXT_ACTIVE_DIR}
fpm_pool_available_dir=${PHP_FPM_POOL_AVAILABLE_DIR}
fpm_pool_active_dir=${PHP_FPM_POOL_ACTIVE_DIR}
php_src_dir=${PHP_SRC_DIR}
EOF
}

show_doctor() {
    tmp="$(mktemp_file)"
    printf 'check\tstatus\tdetails\n' > "${tmp}"

    if cmd_exists "${PHP_BIN}"; then
        php_bin_status="ok"
        php_bin_details="$(command -v "${PHP_BIN}" 2>/dev/null || true)"
    else
        php_bin_status="fail"
        php_bin_details="php binary not found"
    fi
    printf 'php_bin\t%s\t%s\n' "${php_bin_status}" "${php_bin_details}" >> "${tmp}"

    loaded_ini="$(php_loaded_ini)"
    if [ -n "${loaded_ini}" ] && [ "${loaded_ini}" != "(none)" ]; then
        ini_status="ok"
        ini_details="${loaded_ini}"
    else
        ini_status="warn"
        ini_details="no loaded php.ini"
    fi
    printf 'loaded_ini\t%s\t%s\n' "${ini_status}" "${ini_details}" >> "${tmp}"

    extdir="$(php_extension_dir)"
    if [ -n "${extdir}" ] && [ -d "${extdir}" ]; then
        extdir_status="ok"
        extdir_details="${extdir}"
    else
        extdir_status="warn"
        extdir_details="${extdir:-extension_dir missing}"
    fi
    printf 'extension_dir\t%s\t%s\n' "${extdir_status}" "${extdir_details}" >> "${tmp}"

    if [ -d "${PHP_EXT_ACTIVE_DIR}" ]; then
        active_dir_status="ok"
        active_dir_details="${PHP_EXT_ACTIVE_DIR}"
    else
        active_dir_status="warn"
        active_dir_details="missing: ${PHP_EXT_ACTIVE_DIR}"
    fi
    printf 'ext_active_dir\t%s\t%s\n' "${active_dir_status}" "${active_dir_details}" >> "${tmp}"

    if [ -d "${PHP_EXT_AVAILABLE_DIR}" ]; then
        avail_dir_status="ok"
        avail_dir_details="${PHP_EXT_AVAILABLE_DIR}"
    else
        avail_dir_status="warn"
        avail_dir_details="missing: ${PHP_EXT_AVAILABLE_DIR}"
    fi
    printf 'ext_available_dir\t%s\t%s\n' "${avail_dir_status}" "${avail_dir_details}" >> "${tmp}"

    if cmd_exists "${PHP_FPM_BIN}"; then
        fpm_bin_status="ok"
        fpm_bin_details="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || true)"
    else
        fpm_bin_status="info"
        fpm_bin_details="php-fpm binary not available"
    fi
    printf 'php_fpm_bin\t%s\t%s\n' "${fpm_bin_status}" "${fpm_bin_details}" >> "${tmp}"

    if cmd_exists "${PHP_FPM_BIN}"; then
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            fpm_test_status="ok"
            fpm_test_details="configuration valid"
        else
            fpm_test_status="warn"
            fpm_test_details="configuration test failed"
        fi
    else
        fpm_test_status="info"
        fpm_test_details="skipped"
    fi
    printf 'php_fpm_test\t%s\t%s\n' "${fpm_test_status}" "${fpm_test_details}" >> "${tmp}"

    if [ -d "${PHP_SRC_DIR}" ]; then
        src_status="ok"
        src_details="${PHP_SRC_DIR}"
    else
        src_status="warn"
        src_details="missing: ${PHP_SRC_DIR}"
    fi
    printf 'php_src_dir\t%s\t%s\n' "${src_status}" "${src_details}" >> "${tmp}"

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

