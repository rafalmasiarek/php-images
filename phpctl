fpm_pool_bundle_import() {
    json_string=""
    json_file=""
    do_reload="no"

    while [ $# -gt 0 ]; do
        case "$1" in
            --json)
                shift
                [ $# -gt 0 ] || die "Missing value for --json"
                json_string="$1"
                shift
                ;;
            --json-file)
                shift
                [ $# -gt 0 ] || die "Missing value for --json-file"
                json_file="$1"
                shift
                ;;
            --reload)
                do_reload="yes"
                shift
                ;;
            -h|--help)
                fpm_pool_bundle_usage
                return 0
                ;;
            *)
                die "Unknown pool bundle import option: $1"
                ;;
        esac
    done

    [ -n "${json_string}" ] || [ -n "${json_file}" ] || die "One of --json or --json-file is required"
    [ -z "${json_string}" ] || [ -z "${json_file}" ] || die "Use only one of --json or --json-file"

    input_file="$(mktemp_file)"
    result_file="$(mktemp_file)"

    if [ -n "${json_file}" ]; then
        [ -f "${json_file}" ] || { rm -f "${input_file}" "${result_file}"; die "JSON file not found: ${json_file}"; }
        cp "${json_file}" "${input_file}"
    else
        printf '%s\n' "${json_string}" > "${input_file}"
    fi

    mkdir -p "${PHP_FPM_POOL_AVAILABLE_DIR}" "${PHP_FPM_POOL_ACTIVE_DIR}"

    PHPCTL_JSON_FILE="${input_file}" \
    PHPCTL_RESULT_FILE="${result_file}" \
    PHPCTL_SELF_PATH="${SELF_PATH}" \
    "${PHP_BIN}" -r '
        function fail(string $message): void {
            fwrite(STDERR, $message . PHP_EOL);
            exit(1);
        }

        function writeParamsFile(array $params): string {
            $file = tempnam(sys_get_temp_dir(), "phpctl_pool_params_");
            if ($file === false) {
                fail("Unable to create params file");
            }
            $lines = [];
            foreach ($params as $k => $v) {
                $lines[] = $k . "=" . (string) $v;
            }
            file_put_contents($file, implode(PHP_EOL, $lines) . PHP_EOL);
            return $file;
        }

        function buildMetaArgs(array $meta): array {
            $args = [];
            foreach ($meta as $k => $v) {
                if (is_scalar($v) || $v === null) {
                    $args[] = "--meta";
                    $args[] = (string) $k . "=" . (string) $v;
                }
            }
            return $args;
        }

        $json = file_get_contents(getenv("PHPCTL_JSON_FILE"));
        if ($json === false || trim($json) === "") {
            fail("Empty JSON bundle");
        }

        $data = json_decode($json, true);
        if (!is_array($data)) {
            fail("Invalid JSON bundle");
        }

        $defaultEnabled = isset($data["enabled"]) ? (bool) $data["enabled"] : true;
        $pools = $data["pools"] ?? null;
        if (!is_array($pools)) {
            fail("Bundle must contain pools array");
        }

        $result = [];

        foreach ($pools as $pool) {
            if (!is_array($pool)) {
                fail("Invalid pool entry");
            }

            $name = (string) ($pool["name"] ?? "");
            if ($name === "") {
                fail("Pool name is required");
            }

            $template = (string) ($pool["template"] ?? "");
            $enabled = array_key_exists("enabled", $pool) ? (bool) $pool["enabled"] : $defaultEnabled;
            $params = $pool["params"] ?? [];
            $meta = $pool["meta"] ?? [];
            if (!is_array($params)) {
                fail("Pool params must be an object");
            }
            if (!is_array($meta)) {
                fail("Pool meta must be an object");
            }

            $renderParams = [
                "POOL_NAME" => $name,
                "USER" => "www-data",
                "GROUP" => "www-data",
                "LISTEN" => "/var/run/php-fpm-" . $name . ".sock",
                "LISTEN_OWNER" => "www-data",
                "LISTEN_GROUP" => "www-data",
                "PM" => "dynamic",
                "PM_MAX_CHILDREN" => "8",
                "PM_START_SERVERS" => "2",
                "PM_MIN_SPARE_SERVERS" => "1",
                "PM_MAX_SPARE_SERVERS" => "3",
                "CATCH_WORKERS_OUTPUT" => "yes",
                "CLEAR_ENV" => "no",
                "ENABLE_METRICS" => "false",
                "STATUS_PATH" => "",
                "ENABLE_PING" => "false",
                "PING_PATH" => "",
                "PING_RESPONSE" => "",
            ];

            foreach ($params as $k => $v) {
                $renderParams[(string) $k] = is_scalar($v) || $v === null ? (string) $v : json_encode($v);
            }

            $paramsFile = writeParamsFile($renderParams);
            $cmd = [getenv("PHPCTL_SELF_PATH"), "fpm", "pool", "upsert", $name, "--params-file", $paramsFile];

            if ($template !== "") {
                $cmd[] = "--template";
                $cmd[] = $template;
            }

            foreach (buildMetaArgs($meta) as $metaArg) {
                $cmd[] = $metaArg;
            }

            if ($enabled) {
                $cmd[] = "--enable";
            }

            $descriptors = [
                0 => ["pipe", "r"],
                1 => ["pipe", "w"],
                2 => ["pipe", "w"],
            ];
            $proc = proc_open($cmd, $descriptors, $pipes);
            if (!is_resource($proc)) {
                @unlink($paramsFile);
                fail("Unable to execute phpctl for pool " . $name);
            }

            fclose($pipes[0]);
            $stdout = stream_get_contents($pipes[1]);
            $stderr = stream_get_contents($pipes[2]);
            fclose($pipes[1]);
            fclose($pipes[2]);
            $exitCode = proc_close($proc);
            @unlink($paramsFile);

            if ($exitCode !== 0) {
                fail("Pool " . $name . " failed: " . trim((string) $stderr));
            }

            $result[] = [
                "name" => $name,
                "enabled" => $enabled,
                "stdout" => trim((string) $stdout),
            ];
        }

        file_put_contents(getenv("PHPCTL_RESULT_FILE"), json_encode($result, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
    '

    if [ "${do_reload}" = "yes" ]; then
        fpm_reload >/dev/null 2>&1 || true
    fi

    case "${OUTPUT_FORMAT}" in
        text)
            printf 'ok: yes\n'
            printf 'action: bundle-import\n'
            printf 'reload: %s\n' "${do_reload}"
            printf 'result: %s\n' "$(cat "${result_file}")"
            ;;
        json|tsv)
            emit_object <<EOF
ok=yes
action=bundle-import
reload=${do_reload}
result=$(cat "${result_file}")
EOF
            ;;
        *)
            rm -f "${input_file}" "${result_file}"
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${input_file}" "${result_file}"
}

fpm_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} fpm <subcommand> [args]

Subcommands:
  status               Show php-fpm binary and config test result
  test                 Run php-fpm -t
  configtest           Alias of test
  reload               Reload php-fpm master process
  capacity             Show worker pool capacity and usage
  pool list            List available and active pools
  pool render <name>   Render pool file content
  pool create <name>   Create pool config in the available dir
  pool upsert <name>   Create or update pool config in the available dir
  pool generate <name> Generate pool config for manual editing
  pool import <name>   Import existing pool config file
  pool bundle import   Import multiple pools from JSON
  pool enable <name>   Enable pool config by linking it into active dir
  pool disable <name>  Disable pool config by removing it from active dir
  pool delete <name>   Delete pool config
  pool content <name>  Show raw pool config content
  pool validate <name> Validate pool config by running php-fpm -t
  pool show <name>     Show pool metadata and file paths
  help                 Show this help
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=fpm
usage=${PROG} fpm <subcommand> [args]
subcommands=status,test,configtest,reload,capacity,pool list,pool render,pool create,pool upsert,pool generate,pool import,pool bundle import,pool enable,pool disable,pool delete,pool content,pool validate,pool show,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

fpm_status() {
    bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    available="no"
    config_ok="no"

    if cmd_exists "${PHP_FPM_BIN}"; then
        available="yes"
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            config_ok="yes"
        fi
    fi

    emit_object <<EOF
php_fpm_bin=${bin_path}
available=${available}
config_ok=${config_ok}
master_pid=$(php_fpm_master_pid 2>/dev/null || printf '%s' -)
EOF
}

fpm_test() {
    if ! cmd_exists "${PHP_FPM_BIN}"; then
        die "php-fpm binary not found"
    fi

    if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
        status="ok"
        ok="yes"
        details="configuration valid"
    else
        status="fail"
        ok="no"
        details="configuration invalid"
    fi

    emit_object <<EOF
ok=${ok}
status=${status}
details=${details}
EOF
}

fpm_reload() {
    cmd_exists "${PHP_FPM_BIN}" || die "php-fpm binary not found"
    "${PHP_FPM_BIN}" -t >/dev/null 2>&1 || die "php-fpm configuration invalid"

    pid="$(php_fpm_master_pid 2>/dev/null || true)"
    [ -n "${pid}" ] || die "php-fpm master process not found"

    kill -s "${PHP_FPM_RELOAD_SIGNAL}" "${pid}" >/dev/null 2>&1 || die "Unable to send reload signal"

    emit_object <<EOF
ok=yes
status=ok
signal=${PHP_FPM_RELOAD_SIGNAL}
pid=${pid}
details=reloaded
EOF
}

fpm_capacity() {
    usage_file="$(mktemp_file)"
    worker_usage_collect > "${usage_file}"

    pool_count="$(sed -n 's/^pool_count=//p' "${usage_file}" | head -n1)"
    active_pool_count="$(sed -n 's/^active_pool_count=//p' "${usage_file}" | head -n1)"
    sum_pm_max_children="$(sed -n 's/^sum_pm_max_children=//p' "${usage_file}" | head -n1)"
    replicas="$(sed -n 's/^replicas=//p' "${usage_file}" | head -n1)"
    rm -f "${usage_file}"

    free_pools="-"
    free_children="-"
    free_replicas="-"

    case "${PHPCTL_WORKER_MAX_POOLS}" in
        ''|0|*[!0-9]*) ;;
        *) free_pools=$((PHPCTL_WORKER_MAX_POOLS - active_pool_count)); [ "${free_pools}" -lt 0 ] && free_pools=0 ;;
    esac

    case "${PHPCTL_WORKER_MAX_CHILDREN_TOTAL}" in
        ''|0|*[!0-9]*) ;;
        *) free_children=$((PHPCTL_WORKER_MAX_CHILDREN_TOTAL - sum_pm_max_children)); [ "${free_children}" -lt 0 ] && free_children=0 ;;
    esac

    case "${PHPCTL_WORKER_MAX_REPLICAS}" in
        ''|0|*[!0-9]*) ;;
        *) free_replicas=$((PHPCTL_WORKER_MAX_REPLICAS - replicas)); [ "${free_replicas}" -lt 0 ] && free_replicas=0 ;;
    esac

    emit_object <<EOF
max_pools=${PHPCTL_WORKER_MAX_POOLS}
max_children_total=${PHPCTL_WORKER_MAX_CHILDREN_TOTAL}
max_replicas=${PHPCTL_WORKER_MAX_REPLICAS}
max_memory_mb=${PHPCTL_WORKER_MAX_MEMORY_MB}
pool_count=${pool_count}
active_pool_count=${active_pool_count}
sum_pm_max_children=${sum_pm_max_children}
replicas=${replicas}
free_pools=${free_pools}
free_children=${free_children}
free_replicas=${free_replicas}
EOF
}

fpm_pool_list() {
    filter=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --filter)
                shift
                [ $# -gt 0 ] || die "Missing value for --filter"
                filter="$1"
                shift
                ;;
            -h|--help)
                case "${OUTPUT_FORMAT}" in
                    text)
                        cat <<EOF
Usage:
  ${PROG} fpm pool list [--filter "key=value,key2=value2"]
EOF
                        ;;
                    json|tsv)
                        emit_object <<EOF
section=fpm_pool_list
usage=${PROG} fpm pool list [--filter "key=value,key2=value2"]
EOF
                        ;;
                    *)
                        die "Unsupported output format: ${OUTPUT_FORMAT}"
                        ;;
                esac
                return 0
                ;;
            *)
                die "Unknown pool list option: $1"
                ;;
        esac
    done

    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_AVAILABLE_DIR}"/*; do
            [ -e "${f}" ] || continue
            pool_name_from_path "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_ACTIVE_DIR}"/*; do
            [ -e "${f}" ] || continue
            case "$(basename "${f}")" in
                *.conf|*.pool.conf) pool_name_from_path "${f}" >> "${tmp_names}" ;;
            esac
        done
    fi

    printf 'name\tavailable\tactive\tlisten\tpm\tpm_max_children\tmanaged_by\tallocation_id\treplica\tavailable_path\tactive_path\tmetadata_json\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r name; do
            [ -n "${name}" ] || continue
            avail="no"
            active="no"
            available_path="-"
            active_path="-"
            ref_file=""

            if resolve_pool_available "${name}" >/dev/null 2>&1; then
                avail="yes"
                available_path="$(resolve_pool_available "${name}")"
                ref_file="${available_path}"
            fi

            if resolve_pool_active "${name}" >/dev/null 2>&1; then
                active="yes"
                active_path="$(resolve_pool_active "${name}")"
                [ -n "${ref_file}" ] || ref_file="${active_path}"
            fi

            [ -n "${ref_file}" ] || continue
            pool_filter_match_file "${ref_file}" "${filter}" "${active}" "${avail}" || continue

            listen="$(pool_config_get_value "${ref_file}" "listen")"
            pm="$(pool_config_get_value "${ref_file}" "pm")"
            pm_max_children="$(pool_config_get_value "${ref_file}" "pm.max_children")"
            managed_by="$(pool_meta_get "${ref_file}" "managed-by")"
            allocation_id="$(pool_meta_get "${ref_file}" "allocation-id")"
            replica="$(pool_meta_get "${ref_file}" "replica")"
            metadata_json="$(pool_meta_all_json "${ref_file}" | tr -d '\n')"

            printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "${name}" "${avail}" "${active}" "${listen}" "${pm}" "${pm_max_children}" "${managed_by}" "${allocation_id}" "${replica}" "${available_path}" "${active_path}" "${metadata_json}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"
    rm -f "${tmp_names}" "${tmp_rows}"
}

fpm_pool_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool enable <name>"
    name="$1"
    src="$(resolve_pool_available "${name}" 2>/dev/null || true)"
    [ -n "${src}" ] || die "Pool not found in available dir: ${name}"

    mkdir -p "${PHP_FPM_POOL_ACTIVE_DIR}"
    ln -sf "${src}" "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")"

    emit_object <<EOF
ok=yes
action=enable
pool=${name}
active=yes
active_path=${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")
EOF
}

fpm_pool_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool disable <name>"
    name="$1"
    dst="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    [ -n "${dst}" ] || die "Pool not active: ${name}"

    rm -f "${dst}"

    emit_object <<EOF
ok=yes
action=disable
pool=${name}
active=no
removed_path=${dst}
EOF
}

fpm_pool_delete() {
    name=""
    filter=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --filter)
                shift
                [ $# -gt 0 ] || die "Missing value for --filter"
                filter="$1"
                shift
                ;;
            -h|--help)
                case "${OUTPUT_FORMAT}" in
                    text)
                        cat <<EOF
Usage:
  ${PROG} fpm pool delete <name>
  ${PROG} fpm pool delete --filter "key=value,key2=value2"
EOF
                        ;;
                    json|tsv)
                        emit_object <<EOF
section=fpm_pool_delete
usage=${PROG} fpm pool delete <name> | ${PROG} fpm pool delete --filter "key=value,key2=value2"
EOF
                        ;;
                    *)
                        die "Unsupported output format: ${OUTPUT_FORMAT}"
                        ;;
                esac
                return 0
                ;;
            *)
                if [ -z "${name}" ]; then
                    name="$1"
                    shift
                else
                    die "Unknown pool delete option: $1"
                fi
                ;;
        esac
    done

    if [ -n "${name}" ] && [ -n "${filter}" ]; then
        die "Use either pool name or --filter, not both"
    fi

    if [ -z "${name}" ] && [ -z "${filter}" ]; then
        die "Provide pool name or --filter"
    fi

    tmp="$(mktemp_file)"
    printf 'name\tavailable_path\tactive_path\tremoved\n' > "${tmp}"

    if [ -n "${name}" ]; then
        active_path="$(resolve_pool_active "${name}" 2>/dev/null || true)"
        available_path="$(resolve_pool_available "${name}" 2>/dev/null || true)"
        [ -n "${active_path}" ] && rm -f "${active_path}"
        [ -n "${available_path}" ] && rm -f "${available_path}"
        printf '%s\t%s\t%s\tyes\n' "${name}" "${available_path:-"-"}" "${active_path:-"-"}" >> "${tmp}"
    else
        names_file="$(mktemp_file)"
        : > "${names_file}"

        if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
            for f in "${PHP_FPM_POOL_AVAILABLE_DIR}"/*.conf; do
                [ -e "${f}" ] || continue
                pool_name_from_path "${f}" >> "${names_file}"
            done
        fi

        if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
            for f in "${PHP_FPM_POOL_ACTIVE_DIR}"/*.conf; do
                [ -e "${f}" ] || continue
                pool_name_from_path "${f}" >> "${names_file}"
            done
        fi

        if [ -s "${names_file}" ]; then
            sort -fu "${names_file}" | while IFS= read -r pool_name; do
                [ -n "${pool_name}" ] || continue
                available_path="$(resolve_pool_available "${pool_name}" 2>/dev/null || true)"
                active_path="$(resolve_pool_active "${pool_name}" 2>/dev/null || true)"
                ref_file="${available_path:-${active_path:-}}"
                [ -n "${ref_file}" ] || continue

                avail="no"
                active="no"
                [ -n "${available_path}" ] && avail="yes"
                [ -n "${active_path}" ] && active="yes"

                pool_filter_match_file "${ref_file}" "${filter}" "${active}" "${avail}" || continue

                [ -n "${active_path}" ] && rm -f "${active_path}"
                [ -n "${available_path}" ] && rm -f "${available_path}"

                printf '%s\t%s\t%s\tyes\n' "${pool_name}" "${available_path:-"-"}" "${active_path:-"-"}"
            done >> "${tmp}"
        fi

        rm -f "${names_file}"
    fi

    render_table_file "${tmp}"
    rm -f "${tmp}"
}

