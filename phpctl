fpm_pool_render() {
    [ $# -gt 0 ] || { fpm_pool_render_usage; return 0; }
    name="$1"
    shift

    template_file=""
    params_override_file=""
    params_file="$(fpm_pool_build_params "${name}")"

    while [ $# -gt 0 ]; do
        case "$1" in
            --template)
                shift
                [ $# -gt 0 ] || { rm -f "${params_file}"; die "Missing value for --template"; }
                template_file="$1"
                shift
                ;;
            --params-file)
                shift
                [ $# -gt 0 ] || { rm -f "${params_file}"; die "Missing value for --params-file"; }
                params_override_file="$1"
                shift
                ;;
            -p|--param)
                shift
                [ $# -gt 0 ] || { rm -f "${params_file}"; die "Missing value for --param"; }
                key="${1%%=*}"
                value="${1#*=}"
                [ "${key}" != "${1}" ] || { rm -f "${params_file}"; die "Invalid param format: $1"; }
                pool_params_set "${params_file}" "${key}" "${value}"
                shift
                ;;
            -h|--help)
                rm -f "${params_file}"
                fpm_pool_render_usage
                return 0
                ;;
            *)
                rm -f "${params_file}"
                die "Unknown pool render option: $1"
                ;;
        esac
    done

    if [ -n "${params_override_file}" ]; then
        pool_params_load_file "${params_file}" "${params_override_file}"
    fi

    case "${OUTPUT_FORMAT}" in
        text)
            fpm_pool_render_content "${name}" "${template_file}" "${params_file}"
            ;;
        json|tsv)
            rendered_file="$(mktemp_file)"
            fpm_pool_render_content "${name}" "${template_file}" "${params_file}" > "${rendered_file}"
            emit_object <<EOF
pool=${name}
template=$( [ -n "${template_file}" ] && printf '%s' "${template_file}" || printf '%s' "${PHP_FPM_POOL_TEMPLATE:-builtin}" )
content=$(tr '\n' ' ' < "${rendered_file}" | sed 's/[[:space:]]\+/ /g')
EOF
            rm -f "${rendered_file}"
            ;;
        *)
            rm -f "${params_file}"
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${params_file}"
}

