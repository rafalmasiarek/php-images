phpctl_run_listener_forever() {
    listen="$1"
    mode="$2"

    cmd_exists "${NC_BIN}" || die "nc binary not found"
    nc_supports_exec || die "Current nc implementation does not support exec mode (-e). BusyBox nc with -e is required for the built-in server."

    case "${listen}" in
        /*)
            nc_supports_unix_sockets || die "Current nc implementation does not support Unix sockets (-U missing)"
            rm -f "${listen}"
            while :; do
                "${NC_BIN}" -l -U "${listen}" -e "${SELF_PATH}" "__${mode}_stdio"
            done
            ;;
        *)
            listen_host="${listen%:*}"
            listen_port="${listen##*:}"
            [ -n "${listen_host}" ] || die "Invalid listen value: ${listen}"
            [ -n "${listen_port}" ] || die "Invalid listen value: ${listen}"
            while :; do
                "${NC_BIN}" -l -p "${listen_port}" -s "${listen_host}" -e "${SELF_PATH}" "__${mode}_stdio"
            done
            ;;
    esac
}

phpctl_server_run() {
    listen="${PHPCTL_SERVER_LISTEN}"

    while [ $# -gt 0 ]; do
        case "$1" in
            --listen)
                shift
                [ $# -gt 0 ] || die "Missing value for --listen"
                listen="$1"
                shift
                ;;
            -h|--help)
                server_usage
                return 0
                ;;
            *)
                die "Unknown server option: $1"
                ;;
        esac
    done

    phpctl_validate_endpoint "${listen}" || die "Invalid listen value: ${listen}"

    case "${OUTPUT_FORMAT}" in
        text)
            printf 'server_listen: %s\n' "${listen}" >&2
            ;;
        json|tsv)
            emit_object <<EOF
listen=${listen}
mode=server
transport=nc-exec
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    phpctl_run_listener_forever "${listen}" "server"
}

