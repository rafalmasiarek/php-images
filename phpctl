show_worker_health() {
    php_ok="no"
    fpm_ok="no"
    config_ok="no"
    healthy="no"

    if cmd_exists "${PHP_BIN}" && "${PHP_BIN}" -v >/dev/null 2>&1; then
        php_ok="yes"
    fi

    if cmd_exists "${PHP_FPM_BIN}"; then
        pid="$(php_fpm_master_pid 2>/dev/null || true)"
        if [ -n "${pid}" ] && kill -0 "${pid}" >/dev/null 2>&1; then
            fpm_ok="yes"
        fi
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            config_ok="yes"
        fi
    fi

    if [ "${php_ok}" = "yes" ] && [ "${config_ok}" = "yes" ]; then
        healthy="yes"
    fi

    emit_object <<EOF
healthy=${healthy}
php=${php_ok}
fpm=${fpm_ok}
config_valid=${config_ok}
worker_id=$(worker_detect_id)
worker_group=$(worker_detect_group)
EOF

    [ "${healthy}" = "yes" ] || exit 1
}

worker_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} worker <info|capacity|usage|health|help>
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=worker
usage=${PROG} worker <info|capacity|usage|health|help>
subcommands=info,capacity,usage,health,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

handle_worker() {
    [ $# -gt 0 ] || { worker_usage; return 0; }

    case "$1" in
        help|--help|-h)
            worker_usage
            ;;
        info)
            shift
            show_worker_info "$@"
            ;;
        capacity)
            shift
            show_worker_capacity "$@"
            ;;
        usage)
            shift
            show_worker_usage "$@"
            ;;
        health)
            shift
            show_worker_health "$@"
            ;;
        *)
            die "Unknown worker subcommand: $1"
            ;;
    esac
}

pool_name_from_path() {
    base="$(basename "$1")"
    base="${base%.pool.conf}"
    base="${base%.conf}"
    printf '%s\n' "${base}"
}

pool_config_get_value() {
    file="$1"
    key="$2"
    awk -F '=' -v key="${key}" '
        $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
            v=$0
            sub(/^[^=]*=[[:space:]]*/, "", v)
            sub(/[[:space:]]+$/, "", v)
            print v
            exit
        }
    ' "${file}" 2>/dev/null || true
}

pool_meta_key_normalize() {
    printf '%s\n' "$1" | tr '[:upper:]' '[:lower:]'
}

pool_meta_set() {
    file="$1"
    key="$(pool_meta_key_normalize "$2")"
    value="$3"
    tmp="$(mktemp_file)"
    if [ -f "${file}" ]; then
        awk -v prefix="${PHPCTL_POOL_META_PREFIX}" -v k="${key}" '
            {
                line=$0
                if (line ~ "^;[[:space:]]*" prefix k "=") {
                    next
                }
                print line
            }
        ' "${file}" > "${tmp}" || true
    else
        : > "${tmp}"
    fi
    printf '; %s%s=%s\n' "${PHPCTL_POOL_META_PREFIX}" "${key}" "${value}" >> "${tmp}"
    mv "${tmp}" "${file}"
}

pool_meta_get() {
    file="$1"
    key="$(pool_meta_key_normalize "$2")"
    awk -v prefix="${PHPCTL_POOL_META_PREFIX}" -v k="${key}" '
        {
            line=$0
            sub(/^[[:space:]]*;[[:space:]]*/, "", line)
            if (line ~ "^" prefix k "=") {
                sub("^" prefix k "=", "", line)
                print line
                exit
            }
        }
    ' "${file}" 2>/dev/null || true
}

pool_meta_all_tsv() {
    file="$1"
    awk -v prefix="${PHPCTL_POOL_META_PREFIX}" '
        {
            line=$0
            sub(/^[[:space:]]*;[[:space:]]*/, "", line)
            if (index(line, prefix) == 1) {
                sub("^" prefix, "", line)
                key=line
                sub(/=.*/, "", key)
                value=line
                sub(/^[^=]*=/, "", value)
                print key "\t" value
            }
        }
    ' "${file}" 2>/dev/null || true
}

pool_meta_all_json() {
    file="$1"
    meta_file="$(mktemp_file)"
    pool_meta_all_tsv "${file}" > "${meta_file}"
    POOL_META_FILE="${meta_file}" "${PHP_BIN}" -r '
        $file = getenv("POOL_META_FILE");
        $out = [];
        foreach (@file($file, FILE_IGNORE_NEW_LINES) ?: [] as $line) {
            if ($line === "") {
                continue;
            }
            $parts = explode("\t", $line, 2);
            $k = $parts[0] ?? "";
            $v = $parts[1] ?? "";
            if ($k === "") {
                continue;
            }
            $out[$k] = $v;
        }
        ksort($out, SORT_NATURAL | SORT_FLAG_CASE);
        echo json_encode($out, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE), PHP_EOL;
    '
    rm -f "${meta_file}"
}

pool_content_without_metadata() {
    file="$1"
    awk -v prefix="${PHPCTL_POOL_META_PREFIX}" '
        {
            line=$0
            stripped=line
            sub(/^[[:space:]]*;[[:space:]]*/, "", stripped)
            if (index(stripped, prefix) == 1) {
                next
            }
            print line
        }
    ' "${file}"
}

pool_compose_file_with_metadata() {
    content_file="$1"
    metadata_file="$2"
    target_file="$3"

    : > "${target_file}"

    if [ -s "${metadata_file}" ]; then
        while IFS='	' read -r key value; do
            [ -n "${key}" ] || continue
            printf '; %s%s=%s\n' "${PHPCTL_POOL_META_PREFIX}" "$(pool_meta_key_normalize "${key}")" "${value}" >> "${target_file}"
        done < "${metadata_file}"
    fi

    cat "${content_file}" >> "${target_file}"
}

pool_filter_match_file() {
    file="$1"
    filter="$2"
    active="$3"
    available="$4"

    [ -n "${filter}" ] || return 0

    filter_file="$(mktemp_file)"
    printf '%s\n' "${filter}" | tr ',' '\n' > "${filter_file}"

    while IFS= read -r condition; do
        [ -n "${condition}" ] || continue
        key="${condition%%=*}"
        value="${condition#*=}"

        [ "${key}" != "${condition}" ] || { rm -f "${filter_file}"; return 1; }

        norm_key="$(pool_meta_key_normalize "${key}")"
        case "${norm_key}" in
            name)
                actual="$(pool_name_from_path "${file}")"
                ;;
            active)
                actual="${active}"
                ;;
            available)
                actual="${available}"
                ;;
            path)
                actual="${file}"
                ;;
            listen|pm|pm.max_children|pm.start_servers|pm.min_spare_servers|pm.max_spare_servers|user|group)
                actual="$(pool_config_get_value "${file}" "${norm_key}")"
                ;;
            *)
                actual="$(pool_meta_get "${file}" "${norm_key}")"
                ;;
        esac

        if [ "${actual:-}" != "${value}" ]; then
            rm -f "${filter_file}"
            return 1
        fi
    done < "${filter_file}"

    rm -f "${filter_file}"
    return 0
}

resolve_pool_available() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.pool.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done
    return 1
}

resolve_pool_active() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.pool.conf" \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}"
    do
        [ -e "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done
    return 1
}

