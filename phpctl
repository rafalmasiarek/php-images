}

resolve_pool_available() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.pool.conf" \
        "${PHP_FPM_POOL_AVAILABLE_DIR}/${name}"
    do
        [ -f "${candidate}" ] && { printf '%s\n' "${candidate}"; return 0; }
    done
    return 1
}

resolve_pool_active() {
    name="$1"
    for candidate in \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.conf" \
        "${PHP_FPM_POOL_ACTIVE_DIR}/${name}.pool.conf" \
