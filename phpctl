}

fpm_pool_import() {
    [ $# -gt 0 ] || { fpm_pool_import_usage; return 0; }
    name="$1"
    shift

    src=""
    enable_after="no"

    while [ $# -gt 0 ]; do
        case "$1" in
            --from)
                shift
                [ $# -gt 0 ] || die "Missing value for --from"
                src="$1"
                shift
                ;;
            --enable)
                enable_after="yes"
                shift
                ;;
            -h|--help)
                fpm_pool_import_usage
                return 0
                ;;
            *)
                die "Unknown pool import option: $1"
                ;;
        esac
    done

    [ -n "${src}" ] || die "Missing required option --from"
    [ -f "${src}" ] || die "Pool source file not found: ${src}"

    mkdir -p "${PHP_FPM_POOL_AVAILABLE_DIR}"
    target="${PHP_FPM_POOL_AVAILABLE_DIR}/${name}.conf"
    cp "${src}" "${target}"

    if [ "${enable_after}" = "yes" ]; then
        mkdir -p "${PHP_FPM_POOL_ACTIVE_DIR}"
        ln -sf "${target}" "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${target}")"
    fi

    emit_object <<EOF
ok=yes
action=import
pool=${name}
available=yes
active=${enable_after}
available_path=${target}
active_path=$( [ "${enable_after}" = "yes" ] && printf '%s' "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${target}")" || printf '%s' "-" )
EOF
}

# Import multiple pools from JSON without requiring a mounted volume.
fpm_pool_bundle_import() {
    json_string=""
    json_file=""
    do_reload="no"

    while [ $# -gt 0 ]; do
        case "$1" in
            --json)
                shift
                [ $# -gt 0 ] || die "Missing value for --json"
                json_string="$1"
                shift
                ;;
            --json-file)
                shift
                [ $# -gt 0 ] || die "Missing value for --json-file"
                json_file="$1"
                shift
                ;;
            --reload)
                do_reload="yes"
                shift
                ;;
            -h|--help)
                fpm_pool_bundle_usage
                return 0
                ;;
            *)
                die "Unknown pool bundle import option: $1"
                ;;
        esac
    done

    [ -n "${json_string}" ] || [ -n "${json_file}" ] || die "One of --json or --json-file is required"
    [ -z "${json_string}" ] || [ -z "${json_file}" ] || die "Use only one of --json or --json-file"

    input_file="$(mktemp_file)"
    result_file="$(mktemp_file)"

    if [ -n "${json_file}" ]; then
        [ -f "${json_file}" ] || { rm -f "${input_file}" "${result_file}"; die "JSON file not found: ${json_file}"; }
        cp "${json_file}" "${input_file}"
    else
        printf '%s\n' "${json_string}" > "${input_file}"
    fi

    mkdir -p "${PHP_FPM_POOL_AVAILABLE_DIR}" "${PHP_FPM_POOL_ACTIVE_DIR}"

    PHPCTL_JSON_FILE="${input_file}" \
    PHPCTL_TEMPLATE_DEFAULT="${PHP_FPM_POOL_TEMPLATE}" \
    PHPCTL_POOL_AVAILABLE_DIR="${PHP_FPM_POOL_AVAILABLE_DIR}" \
    PHPCTL_POOL_ACTIVE_DIR="${PHP_FPM_POOL_ACTIVE_DIR}" \
    PHPCTL_RESULT_FILE="${result_file}" \
    PHPCTL_SELF_PATH="$0" \
    "${PHP_BIN}" -r '
        function fail(string $message): void {
            fwrite(STDERR, $message . PHP_EOL);
            exit(1);
        }

        function writeParamsFile(array $params): string {
            $file = tempnam(sys_get_temp_dir(), "phpctl_pool_params_");
            if ($file === false) {
                fail("Unable to create params file");
            }
            $lines = [];
            foreach ($params as $k => $v) {
                $lines[] = $k . "=" . (string) $v;
            }
            file_put_contents($file, implode(PHP_EOL, $lines) . PHP_EOL);
            return $file;
        }

        $json = file_get_contents(getenv("PHPCTL_JSON_FILE"));
        if ($json === false || trim($json) === "") {
            fail("Empty JSON bundle");
        }

        $data = json_decode($json, true);
        if (!is_array($data)) {
            fail("Invalid JSON bundle");
        }

        $defaultEnabled = isset($data["enabled"]) ? (bool) $data["enabled"] : true;
        $pools = $data["pools"] ?? null;
        if (!is_array($pools)) {
            fail("Bundle must contain pools array");
        }

        $result = [];

        foreach ($pools as $pool) {
            if (!is_array($pool)) {
                fail("Invalid pool entry");
            }

            $name = (string) ($pool["name"] ?? "");
            if ($name === "") {
                fail("Pool name is required");
            }

            $template = (string) ($pool["template"] ?? "");
            $enabled = array_key_exists("enabled", $pool) ? (bool) $pool["enabled"] : $defaultEnabled;
            $params = $pool["params"] ?? [];
            if (!is_array($params)) {
                fail("Pool params must be an object");
            }

            $renderParams = [
                "POOL_NAME" => $name,
                "USER" => "www-data",
                "GROUP" => "www-data",
                "LISTEN" => "/var/run/php-fpm-" . $name . ".sock",
                "LISTEN_OWNER" => "www-data",
                "LISTEN_GROUP" => "www-data",
                "PM" => "dynamic",
                "PM_MAX_CHILDREN" => "8",
                "PM_START_SERVERS" => "2",
                "PM_MIN_SPARE_SERVERS" => "1",
                "PM_MAX_SPARE_SERVERS" => "3",
                "CATCH_WORKERS_OUTPUT" => "yes",
                "CLEAR_ENV" => "no",
                "ENABLE_METRICS" => "false",
                "STATUS_PATH" => "",
                "ENABLE_PING" => "false",
                "PING_PATH" => "",
                "PING_RESPONSE" => "",
            ];

            foreach ($params as $k => $v) {
                $renderParams[(string) $k] = is_scalar($v) || $v === null ? (string) $v : json_encode($v);
            }

            $paramsFile = writeParamsFile($renderParams);
            $cmd = [getenv("PHPCTL_SELF_PATH"), "fpm", "pool", "create", $name, "--params-file", $paramsFile];
            if ($template !== "") {
                $cmd[] = "--template";
                $cmd[] = $template;
            }
            if ($enabled) {
                $cmd[] = "--enable";
            }

            $descriptors = [
                0 => ["pipe", "r"],
                1 => ["pipe", "w"],
                2 => ["pipe", "w"],
            ];
            $proc = proc_open($cmd, $descriptors, $pipes);
            if (!is_resource($proc)) {
                @unlink($paramsFile);
                fail("Unable to execute phpctl for pool " . $name);
            }

            fclose($pipes[0]);
            $stdout = stream_get_contents($pipes[1]);
            $stderr = stream_get_contents($pipes[2]);
            fclose($pipes[1]);
            fclose($pipes[2]);
            $exitCode = proc_close($proc);
            @unlink($paramsFile);

            if ($exitCode !== 0) {
                fail("Pool " . $name . " failed: " . trim((string) $stderr));
            }

            $result[] = [
                "name" => $name,
                "enabled" => $enabled,
                "stdout" => trim((string) $stdout),
            ];
        }

        file_put_contents(getenv("PHPCTL_RESULT_FILE"), json_encode($result, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
    '

    if [ "${do_reload}" = "yes" ]; then
        fpm_reload >/dev/null 2>&1 || true
    fi

    case "${OUTPUT_FORMAT}" in
        text)
            printf 'ok: yes\n'
            printf 'action: bundle-import\n'
            printf 'reload: %s\n' "${do_reload}"
            printf 'result: %s\n' "$(cat "${result_file}")"
            ;;
        json|tsv)
            emit_object <<EOF
ok=yes
action=bundle-import
reload=${do_reload}
result=$(cat "${result_file}")
EOF
            ;;
        *)
            rm -f "${input_file}" "${result_file}"
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    rm -f "${input_file}" "${result_file}"
}

fpm_usage() {
    case "${OUTPUT_FORMAT}" in
        text)
            cat <<EOF
Usage:
  ${PROG} fpm <subcommand> [args]

Subcommands:
  status               Show php-fpm binary and config test result
  test                 Run php-fpm -t
  configtest           Alias of test
  reload               Reload php-fpm master process
  pool list            List available and active pools
  pool render <name>   Render pool file content
  pool create <name>   Create pool config in the available dir
  pool generate <name> Generate pool config for manual editing
  pool import <name>   Import existing pool config file
  pool bundle import   Import multiple pools from JSON
  pool enable <name>   Enable pool config by linking it into active dir
  pool disable <name>  Disable pool config by removing it from active dir
  pool delete <name>   Delete pool config
  pool validate <name> Validate pool config by running php-fpm -t
  pool show <name>     Show pool file paths
  help                 Show this help
EOF
            ;;
        json|tsv)
            emit_object <<EOF
section=fpm
usage=${PROG} fpm <subcommand> [args]
subcommands=status,test,configtest,reload,pool list,pool render,pool create,pool generate,pool import,pool bundle import,pool enable,pool disable,pool delete,pool validate,pool show,help
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac
}

fpm_status() {
    bin_path="$(command -v "${PHP_FPM_BIN}" 2>/dev/null || printf '%s\n' "not-found")"
    available="no"
    config_ok="no"

    if cmd_exists "${PHP_FPM_BIN}"; then
        available="yes"
        if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
            config_ok="yes"
        fi
    fi

    emit_object <<EOF
php_fpm_bin=${bin_path}
available=${available}
config_ok=${config_ok}
master_pid=$(php_fpm_master_pid 2>/dev/null || printf '%s' -)
EOF
}

fpm_test() {
    if ! cmd_exists "${PHP_FPM_BIN}"; then
        die "php-fpm binary not found"
    fi

    if "${PHP_FPM_BIN}" -t >/dev/null 2>&1; then
        status="ok"
        ok="yes"
        details="configuration valid"
    else
        status="fail"
        ok="no"
        details="configuration invalid"
    fi

    emit_object <<EOF
ok=${ok}
status=${status}
details=${details}
EOF
}

fpm_reload() {
    cmd_exists "${PHP_FPM_BIN}" || die "php-fpm binary not found"
    "${PHP_FPM_BIN}" -t >/dev/null 2>&1 || die "php-fpm configuration invalid"

    pid="$(php_fpm_master_pid 2>/dev/null || true)"
    [ -n "${pid}" ] || die "php-fpm master process not found"

    kill -s "${PHP_FPM_RELOAD_SIGNAL}" "${pid}" >/dev/null 2>&1 || die "Unable to send reload signal"

    emit_object <<EOF
ok=yes
status=ok
signal=${PHP_FPM_RELOAD_SIGNAL}
pid=${pid}
details=reloaded
EOF
}

fpm_pool_list() {
    tmp_names="$(mktemp_file)"
    tmp_rows="$(mktemp_file)"
    : > "${tmp_names}"

    if [ -d "${PHP_FPM_POOL_AVAILABLE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_AVAILABLE_DIR}"/*; do
            [ -e "${f}" ] || continue
            pool_name_from_path "${f}" >> "${tmp_names}"
        done
    fi

    if [ -d "${PHP_FPM_POOL_ACTIVE_DIR}" ]; then
        for f in "${PHP_FPM_POOL_ACTIVE_DIR}"/*; do
            [ -e "${f}" ] || continue
            case "$(basename "${f}")" in
                *.conf|*.pool.conf) pool_name_from_path "${f}" >> "${tmp_names}" ;;
            esac
        done
    fi

    printf 'name\tavailable\tactive\tavailable_path\tactive_path\n' > "${tmp_rows}"

    if [ -s "${tmp_names}" ]; then
        sort -fu "${tmp_names}" | while IFS= read -r name; do
            [ -n "${name}" ] || continue
            avail="no"
            active="no"
            available_path="-"
            active_path="-"

            if resolve_pool_available "${name}" >/dev/null 2>&1; then
                avail="yes"
                available_path="$(resolve_pool_available "${name}")"
            fi

            if resolve_pool_active "${name}" >/dev/null 2>&1; then
                active="yes"
                active_path="$(resolve_pool_active "${name}")"
            fi

            printf '%s\t%s\t%s\t%s\t%s\n' "${name}" "${avail}" "${active}" "${available_path}" "${active_path}"
        done >> "${tmp_rows}"
    fi

    render_table_file "${tmp_rows}"

    rm -f "${tmp_names}" "${tmp_rows}"
}

fpm_pool_enable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool enable <name>"
    name="$1"
    src="$(resolve_pool_available "${name}" 2>/dev/null || true)"
    [ -n "${src}" ] || die "Pool not found in available dir: ${name}"

    mkdir -p "${PHP_FPM_POOL_ACTIVE_DIR}"
    ln -sf "${src}" "${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")"

    emit_object <<EOF
ok=yes
action=enable
pool=${name}
active=yes
active_path=${PHP_FPM_POOL_ACTIVE_DIR}/$(basename "${src}")
EOF
}

fpm_pool_disable() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool disable <name>"
    name="$1"
    dst="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    [ -n "${dst}" ] || die "Pool not active: ${name}"

    rm -f "${dst}"

    emit_object <<EOF
ok=yes
action=disable
pool=${name}
active=no
removed_path=${dst}
EOF
}

fpm_pool_delete() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool delete <name>"
    name="$1"

    active_path="$(resolve_pool_active "${name}" 2>/dev/null || true)"
    available_path="$(resolve_pool_available "${name}" 2>/dev/null || true)"

    [ -n "${active_path}" ] && rm -f "${active_path}"
    [ -n "${available_path}" ] && rm -f "${available_path}"

    emit_object <<EOF
ok=yes
action=delete
pool=${name}
removed=yes
EOF
}

fpm_pool_validate() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool validate <name>"
    name="$1"
    resolve_pool_available "${name}" >/dev/null 2>&1 || die "Pool not found in available dir: ${name}"
    fpm_test
}

fpm_pool_show() {
    [ $# -eq 1 ] || die "Usage: ${PROG} fpm pool show <name>"
    name="$1"

    avail="no"
    active="no"
    available_path="-"
    active_path="-"

    if resolve_pool_available "${name}" >/dev/null 2>&1; then
        avail="yes"
        available_path="$(resolve_pool_available "${name}")"
    fi

    if resolve_pool_active "${name}" >/dev/null 2>&1; then
        active="yes"
        active_path="$(resolve_pool_active "${name}")"
    fi

    emit_object <<EOF
pool=${name}
available=${avail}
active=${active}
available_path=${available_path}
active_path=${active_path}
EOF
}

handle_fpm() {
    [ $# -gt 0 ] || { fpm_usage; return 0; }

    case "$1" in
        help|--help|-h)
            fpm_usage
            ;;
        status)
            shift
            fpm_status "$@"
            ;;
        test)
            shift
            fpm_test "$@"
            ;;
        configtest)
            shift
            fpm_test "$@"
            ;;
        reload)
            shift
            fpm_reload "$@"
            ;;
        pool)
            shift
            [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool <list|render|create|generate|import|bundle|enable|disable|delete|validate|show> ..."
            case "$1" in
                help|--help|-h)
                    fpm_usage
                    ;;
                list)
                    shift
                    fpm_pool_list "$@"
                    ;;
                render)
                    shift
                    fpm_pool_render "$@"
                    ;;
                create)
                    shift
                    fpm_pool_create "$@"
                    ;;
                generate)
                    shift
                    fpm_pool_generate "$@"
                    ;;
                import)
                    shift
                    fpm_pool_import "$@"
                    ;;
                bundle)
                    shift
                    [ $# -gt 0 ] || die "Usage: ${PROG} fpm pool bundle import ..."
                    case "$1" in
                        import)
                            shift
                            fpm_pool_bundle_import "$@"
                            ;;
                        *)
                            die "Unknown fpm pool bundle subcommand: $1"
                            ;;
                    esac
                    ;;
                enable)
                    shift
                    fpm_pool_enable "$@"
                    ;;
                disable)
                    shift
                    fpm_pool_disable "$@"
                    ;;
                delete)
                    shift
                    fpm_pool_delete "$@"
                    ;;
                validate)
                    shift
                    fpm_pool_validate "$@"
                    ;;
                show)
                    shift
                    fpm_pool_show "$@"
                    ;;
                *)
                    die "Unknown fpm pool subcommand: $1"
                    ;;
            esac
            ;;
        *)
            die "Unknown fpm subcommand: $1"
            ;;
    esac
}

