        show)
            shift
            ini_show "$@"
            ;;
        get)
            shift
            ini_get "$@"
            ;;
        scan)
            shift
            ini_scan "$@"
            ;;
        loaded)
            shift
            ini_loaded "$@"
            ;;
        *)
            die "Unknown ini subcommand: $1"
            ;;
    esac
}

