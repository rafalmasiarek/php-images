serve_http() {
    listen="${PHPCTL_SERVE_LISTEN}"

    while [ $# -gt 0 ]; do
        case "$1" in
            --listen)
                shift
                [ $# -gt 0 ] || die "Missing value for --listen"
                listen="$1"
                shift
                ;;
            -h|--help)
                serve_usage
                return 0
                ;;
            *)
                die "Unknown serve option: $1"
                ;;
        esac
    done

    cmd_exists "${NC_BIN}" || die "nc binary not found"

    case "${OUTPUT_FORMAT}" in
        text)
            printf 'serve_listen: %s\n' "${listen}"
            ;;
        json|tsv)
            emit_object <<EOF
listen=${listen}
mode=single-file
transport=nc
EOF
            ;;
        *)
            die "Unsupported output format: ${OUTPUT_FORMAT}"
            ;;
    esac

    while :; do
        req_file="$(mktemp_file)"
        body_file="$(mktemp_file)"
        response_file="$(mktemp_file)"

        if "${NC_BIN}" -l -p "${listen##*:}" > "${req_file}" 2>/dev/null; then
            :
        else
            rm -f "${req_file}" "${body_file}" "${response_file}"
            die "Unable to bind serve listener"
        fi

        request_line="$(head -n1 "${req_file}" 2>/dev/null || true)"
        path="$(printf '%s' "${request_line}" | awk '{print $2}')"

        status_line="404 Not Found"
        content_type="application/json"

        case "${path}" in
            /healthz|/readyz)
                if "${0}" --output json health > "${body_file}" 2>/dev/null; then
                    status_line="200 OK"
                else
                    printf '{"ok":false}\n' > "${body_file}"
                    status_line="503 Service Unavailable"
                fi
                ;;
            /status)
                "${0}" --output json status > "${body_file}"
                status_line="200 OK"
                ;;
            /metrics)
                "${0}" --output text metrics > "${body_file}"
                status_line="200 OK"
                content_type="text/plain; version=0.0.4"
                ;;
            *)
                printf '{"ok":false,"error":"not found"}\n' > "${body_file}"
                ;;
        esac

        body_len="$(wc -c < "${body_file}" | tr -d '[:space:]')"
        {
            printf 'HTTP/1.1 %s\r\n' "${status_line}"
            printf 'Content-Type: %s\r\n' "${content_type}"
            printf 'Content-Length: %s\r\n' "${body_len}"
            printf 'Connection: close\r\n'
            printf '\r\n'
            cat "${body_file}"
        } > "${response_file}"

        cat "${response_file}" | "${NC_BIN}" -l -p "${listen##*:}" >/dev/null 2>&1 || true

        rm -f "${req_file}" "${body_file}" "${response_file}"
    done
}

