{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "timezone": "Europe/Warsaw",
    "labels": [
        "dependencies"
    ],
    "dependencyDashboard": true,
    "schedule": [
        "after 02:00 and before 06:00"
    ],
    "dockerfile": {
        "enabled": true
    },
    "packageRules": [
        {
            "description": "Upgrade base OS/runtime images",
            "matchManagers": [
                "dockerfile"
            ],
            "groupName": "base images"
        },
        {
            "description": "Upgrade PHP patch versions only",
            "matchManagers": [
                "dockerfile"
            ],
            "matchDepNames": [
                "php"
            ],
            "matchUpdateTypes": [
                "major",
                "minor"
            ],
            "enabled": false
        },
        {
            "description": "Upgrade Alpine base OS used by images",
            "matchManagers": [
                "custom.regex"
            ],
            "matchDepNames": [
                "alpine"
            ],
            "allowedVersions": "^3\\.",
            "groupName": "alpine base os"
        },
        {
            "description": "Keep Ruby toolchain stable",
            "matchDepNames": [
                "ruby"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        },
        {
            "description": "Group CI tooling updates",
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "ci tooling"
        },
        {
            "description": "Group web dependencies",
            "matchManagers": [
                "bundler"
            ],
            "groupName": "web dependencies"
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "description": "Track Alpine version embedded in php:<php>-<variant>-alpine<alpine> in Dockerfiles",
            "managerFilePatterns": [
                "/^versions/[^/]+/[^/]+/Dockerfile$/"
            ],
            "matchStrings": [
                "FROM\\s+php:(?<phpVersion>\\d+\\.\\d+\\.\\d+)(?:-[^\\s]+)?-alpine(?<currentValue>\\d+\\.\\d+)"
            ],
            "depNameTemplate": "alpine",
            "datasourceTemplate": "docker",
            "versioningTemplate": "semver"
        }
    ]
}
